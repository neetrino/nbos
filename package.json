{
  "name": "nbos",
  "private": true,
  "description": "NBOS Platform — Business Operation System",
  "packageManager": "pnpm@8.15.0",
  "engines": {
    "node": ">=22.0.0 <23.0.0",
    "pnpm": ">=8.0.0"
  },
  "scripts": {
    "dev": "turbo dev",
    "dev:web": "pnpm --filter @nbos/web dev",
    "dev:api": "pnpm --filter @nbos/api dev",
    "build": "turbo build",
    "build:web": "pnpm --filter @nbos/web build",
    "build:api": "pnpm --filter @nbos/api build",
    "build:full": "pnpm --filter @nbos/api build && pnpm --filter @nbos/web build",
    "start:web": "pnpm --filter @nbos/web start",
    "start:api": "pnpm --filter @nbos/api start",
    "start:full": "node scripts/start-full.mjs",
    "prod:web": "pnpm --filter @nbos/web build && pnpm --filter @nbos/web start",
    "prod:api": "pnpm --filter @nbos/api build && pnpm --filter @nbos/api start",
    "prod:full": "pnpm run build:full && pnpm run start:full",
    "lint": "turbo lint",
    "typecheck": "turbo typecheck",
    "format": "prettier --write \"**/*.{ts,tsx,js,jsx,json,md,css}\"",
    "format:check": "prettier --check \"**/*.{ts,tsx,js,jsx,json,md,css}\"",
    "test": "vitest run",
    "test:regression": "vitest run --config vitest.regression.config.ts",
    "test:coverage": "vitest run --coverage",
    "test:watch": "vitest",
    "knip": "knip --dependencies --files",
    "knip:exports": "knip",
    "clean": "turbo clean && rm -rf node_modules",
    "db:generate": "pnpm --filter @nbos/database generate",
    "db:migrate": "pnpm --filter @nbos/database migrate:dev",
    "db:push": "pnpm --filter @nbos/database push",
    "db:seed": "pnpm --filter @nbos/database seed",
    "db:studio": "pnpm --filter @nbos/database studio",
    "prepare": "husky"
  },
  "devDependencies": {
    "@commitlint/cli": "^19.8.1",
    "@commitlint/config-conventional": "^19.8.1",
    "@vitest/coverage-v8": "^4.1.0",
    "eslint": "^9",
    "husky": "^9.1.7",
    "knip": "^6.15.0",
    "lint-staged": "^16.3.3",
    "prettier": "^3.8.3",
    "prettier-plugin-tailwindcss": "^0.8.0",
    "tsx": "^4.22.4",
    "turbo": "^2.9.16",
    "typescript-eslint": "^8.60.0",
    "vitest": "^4.1.0"
  },
  "pnpm": {
    "overrides": {
      "@hono/node-server": ">=1.19.10",
      "@vitest/coverage-v8": ">=4.1.0",
      "@vitest/mocker": ">=4.1.0",
      "defu": ">=6.1.5",
      "effect": ">=3.20.0",
      "fast-uri": ">=3.1.2",
      "fast-xml-parser": ">=5.5.6",
      "flatted": ">=3.4.2",
      "hono": ">=4.12.4",
      "lodash": ">=4.18.0",
      "path-to-regexp": ">=8.4.0",
      "picomatch@2": ">=2.3.2",
      "picomatch@4": ">=4.0.4",
      "vite": ">=7.3.2",
      "vitest": ">=4.1.0"
    }
  },
  "lint-staged": {
    "*.{ts,tsx,js,jsx,json,md,css}": [
      "pnpm exec prettier --write --ignore-path .prettierignore"
    ],
    "*.{ts,tsx,js,jsx}": [
      "pnpm exec eslint --fix"
    ]
  }
}
