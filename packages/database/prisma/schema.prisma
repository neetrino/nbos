  sortOrder Int      @default(0) @map("sort_order")
  isDefault Boolean  @default(false) @map("is_default")
  createdAt DateTime @default(now()) @map("created_at")

  @@unique([ownerId, boardType, title])
  @@index([ownerId, boardType])
  @@map("task_board_stages")
}

model RecurringTaskTemplate {
  id            String           @id @default(uuid())
  title         String
  description   String?
  assigneeId    String?          @map("assignee_id")
  creatorId     String           @map("creator_id")
  priority      TaskPriorityEnum @default(NORMAL)
  frequency     String
  interval      Int              @default(1)
  daysOfWeek    String[]         @map("days_of_week")
  dayOfMonth    Int?             @map("day_of_month")
  startDate     DateTime         @map("start_date")
  endDate       DateTime?        @map("end_date")
  dueDateOffset Int?             @map("due_date_offset")
  isActive      Boolean          @default(true) @map("is_active")
  lastCreatedAt DateTime?        @map("last_created_at")
  nextCreateAt  DateTime?        @map("next_create_at")
  checklistData Json?            @map("checklist_data")
  linksData     Json?            @map("links_data")
  createdAt     DateTime         @default(now()) @map("created_at")
  updatedAt     DateTime         @updatedAt @map("updated_at")

  creator  Employee  @relation("RecurringTaskCreator", fields: [creatorId], references: [id])
  assignee Employee? @relation("RecurringTaskAssignee", fields: [assigneeId], references: [id])

  @@map("recurring_task_templates")
}

// ─── SUPPORT ──────────────────────────────────────────────

enum TicketCategoryEnum {
  INCIDENT
  SERVICE_REQUEST
  CHANGE_REQUEST
  PROBLEM
}

enum TicketPriorityEnum {
  P1
  P2
  P3
}

enum TicketStatusEnum {
  NEW
  TRIAGED
  ASSIGNED
  IN_PROGRESS
  RESOLVED
  CLOSED
  REOPENED
}

enum SupportCoverageEnum {
  COVERED_BY_MAINTENANCE
  FREE_GOODWILL
  BILLABLE_SMALL_WORK
  EXTENSION_REQUIRED
  NOT_COVERED_REJECTED
}

model SupportTicket {
  id                  String               @id @default(uuid())
  code                String               @unique
  projectId           String               @map("project_id")
  productId           String?              @map("product_id")
  contactId           String?              @map("contact_id")
  extensionDealId     String?              @unique @map("extension_deal_id")
  category            TicketCategoryEnum
  priority            TicketPriorityEnum   @default(P3)
  status              TicketStatusEnum     @default(NEW)
