  adjustmentsTotal Decimal              @default(0) @map("adjustments_total") @db.Decimal(12, 2)
  deductionsTotal  Decimal              @default(0) @map("deductions_total") @db.Decimal(12, 2)
  totalPayable     Decimal              @default(0) @map("total_payable") @db.Decimal(12, 2)
  paidAmount       Decimal              @default(0) @map("paid_amount") @db.Decimal(12, 2)
  remainingAmount  Decimal              @default(0) @map("remaining_amount") @db.Decimal(12, 2)
  status           SalaryLineStatusEnum @default(PENDING)
  expenseId        String?              @unique @map("expense_id")
  createdAt        DateTime             @default(now()) @map("created_at")
  updatedAt        DateTime             @updatedAt @map("updated_at")

  payrollRun PayrollRun @relation(fields: [payrollRunId], references: [id], onDelete: Cascade)
  employee   Employee   @relation(fields: [employeeId], references: [id])
  expense    Expense?   @relation(fields: [expenseId], references: [id])

  @@unique([payrollRunId, employeeId])
  @@index([payrollRunId])
  @@index([employeeId])
  @@map("salary_lines")
