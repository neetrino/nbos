  title               String
  description         String?
  billable            Boolean              @default(false)
  assignedTo          String?              @map("assigned_to")
  slaResponseDeadline DateTime?            @map("sla_response_deadline")
  slaResolveDeadline  DateTime?            @map("sla_resolve_deadline")
  createdAt           DateTime             @default(now()) @map("created_at")
  updatedAt           DateTime             @updatedAt @map("updated_at")

  project       Project   @relation(fields: [projectId], references: [id])
  product       Product?  @relation(fields: [productId], references: [id])
  extensionDeal Deal?     @relation(fields: [extensionDealId], references: [id])
  contact       Contact?  @relation(fields: [contactId], references: [id])
  assignee      Employee? @relation("TicketAssignee", fields: [assignedTo], references: [id])

  @@map("support_tickets")
}

// ─── CREDENTIALS & DOMAINS ────────────────────────────────

enum CredentialCategoryEnum {
  ADMIN
  DOMAIN
  HOSTING
  SERVICE
  APP
  MAIL
  API_KEY
  DATABASE
  OTHER
}

enum CredentialAccessLevelEnum {
  SECRET
  PROJECT_TEAM
  DEPARTMENT
  ALL
  PERSONAL
}

enum CredentialTypeEnum {
  LOGIN_PASSWORD
  API_KEY
  DATABASE
  SSH_PRIVATE_KEY
  ENV_BUNDLE
  DOMAIN_REGISTRAR
  HOSTING_SERVER
  APP_STORE_ACCOUNT
  MAIL_SMTP
  RECOVERY_CODES
  OTHER_SECRET
}

enum CredentialCriticalityEnum {
  LOW
  MEDIUM
  HIGH
  CRITICAL
}

model Credential {
  id                    String                    @id @default(uuid())
  projectId             String?                   @map("project_id")
  productId             String?                   @map("product_id")
  domainId              String?                   @map("domain_id")
  clientServiceRecordId String?                   @map("client_service_record_id")
  departmentId          String?                   @map("department_id")
  ownerId               String?                   @map("owner_id")
  category              CredentialCategoryEnum
  credentialType        CredentialTypeEnum        @default(LOGIN_PASSWORD) @map("credential_type")
  criticality           CredentialCriticalityEnum @default(MEDIUM)
  environment           String?
  provider              String?
  name                  String
  url                   String?
  login                 String?
  password              String?
  apiKey                String?                   @map("api_key")
  envData               String?                   @map("env_data")
  phone                 String?
  notes                 String?
  publicNotes           String?                   @map("public_notes")
  secureNotes           String?                   @map("secure_notes")
  lastRotatedAt         DateTime?                 @map("last_rotated_at")
  nextRotationAt        DateTime?                 @map("next_rotation_at")
  rotationOwnerId       String?                   @map("rotation_owner_id")
  accessLevel           CredentialAccessLevelEnum @default(PROJECT_TEAM) @map("access_level")
  allowedEmployees      String[]                  @map("allowed_employees")
  archivedAt            DateTime?                 @map("archived_at")
  createdAt             DateTime                  @default(now()) @map("created_at")
  updatedAt             DateTime                  @updatedAt @map("updated_at")

  project                 Project?                 @relation(fields: [projectId], references: [id])
  department              Department?              @relation(fields: [departmentId], references: [id])
  owner                   Employee?                @relation("CredentialOwner", fields: [ownerId], references: [id])
  clientServiceRecords    ClientServiceRecord[]
  mailProviderConnections MailProviderConnection[]

  @@index([projectId])
  @@index([productId])
  @@index([domainId])
  @@index([clientServiceRecordId])
  @@index([category])
  @@index([credentialType])
  @@index([criticality])
  @@index([environment])
  @@index([accessLevel])
  @@index([ownerId])
  @@index([nextRotationAt])
  @@map("credentials")
}

enum DomainStatusEnum {
  ACTIVE
  EXPIRING_SOON
  EXPIRED
  TRANSFERRED
}

model Domain {
  id           String           @id @default(uuid())
  projectId    String           @map("project_id")
  domainName   String           @unique @map("domain_name")
  provider     String?
  purchaseDate DateTime?        @map("purchase_date")
  expiryDate   DateTime?        @map("expiry_date")
  renewalCost  Decimal?         @map("renewal_cost") @db.Decimal(10, 2)
  clientCharge Decimal?         @map("client_charge") @db.Decimal(10, 2)
  autoRenew    Boolean          @default(true) @map("auto_renew")
  status       DomainStatusEnum @default(ACTIVE)
  createdAt    DateTime         @default(now()) @map("created_at")
  updatedAt    DateTime         @updatedAt @map("updated_at")

  project Project @relation(fields: [projectId], references: [id])

  @@map("domains")
}

enum ClientServiceType {
  DOMAIN
  HOSTING
  SERVICE
  ACCOUNT
  LICENSE
}

enum ClientServiceStatus {
  PENDING
  ACTIVE
  SUSPENDED
  EXPIRING_SOON
  EXPIRED
  CANCELLED
}

enum ClientServiceBillingModel {
  CLIENT_PAID
  COMPANY_PAID
}

enum ClientServicePricingModel {
  FIXED
  USAGE_BASED
}

model ClientServiceRecord {
  id                   String                    @id @default(uuid())
  projectId            String                    @map("project_id")
  productId            String?                   @map("product_id")
  type                 ClientServiceType
  name                 String
  provider             String?
  providerAccountId    String?                   @map("provider_account_id")
  status               ClientServiceStatus       @default(PENDING)
  billingModel         ClientServiceBillingModel @default(CLIENT_PAID) @map("billing_model")
  pricingModel         ClientServicePricingModel @default(FIXED) @map("pricing_model")
  frequency            ExpenseFrequency          @default(YEARLY)
  ourCost              Decimal?                  @map("our_cost") @db.Decimal(12, 2)
  clientCharge         Decimal?                  @map("client_charge") @db.Decimal(12, 2)
  taxStatus            TaxStatus                 @default(TAX) @map("tax_status")
  notificationsEnabled Boolean                   @default(true) @map("notifications_enabled")
  startDate            DateTime?                 @map("start_date")
  renewalDate          DateTime?                 @map("renewal_date")
  notes                String?
  createdAt            DateTime                  @default(now()) @map("created_at")
  updatedAt            DateTime                  @updatedAt @map("updated_at")

  project         Project       @relation(fields: [projectId], references: [id])
  product         Product?      @relation(fields: [productId], references: [id], onDelete: SetNull)
  providerAccount Credential?   @relation(fields: [providerAccountId], references: [id], onDelete: SetNull)
  invoices        Invoice[]
  expensePlans    ExpensePlan[]
  expenses        Expense[]

  @@index([projectId])
  @@index([productId])
  @@index([providerAccountId])
  @@index([type])
  @@index([status])
  @@index([billingModel])
  @@index([renewalDate])
  @@map("client_service_records")
}

// ─── RBAC: DEPARTMENTS, ROLES, PERMISSIONS ───────────────

model Department {
  id          String       @id @default(uuid())
  name        String
  slug        String       @unique
  description String?
  parentId    String?      @map("parent_id")
  parent      Department?  @relation("DeptHierarchy", fields: [parentId], references: [id])
  children    Department[] @relation("DeptHierarchy")
  sortOrder   Int          @default(0) @map("sort_order")
  createdAt   DateTime     @default(now()) @map("created_at")
  updatedAt   DateTime     @updatedAt @map("updated_at")

  members     EmployeeDepartment[]
  credentials Credential[]
  invitations Invitation[]

  @@map("departments")
}

model EmployeeDepartment {
  id           String   @id @default(uuid())
  employeeId   String   @map("employee_id")
  departmentId String   @map("department_id")
  deptRole     String   @default("MEMBER") @map("dept_role")
  isPrimary    Boolean  @default(false) @map("is_primary")
  joinedAt     DateTime @default(now()) @map("joined_at")

  employee   Employee   @relation(fields: [employeeId], references: [id], onDelete: Cascade)
  department Department @relation(fields: [departmentId], references: [id], onDelete: Cascade)

  @@unique([employeeId, departmentId])
  @@map("employee_departments")
}

model Role {
  id          String   @id @default(uuid())
  name        String
  slug        String   @unique
  description String?
  level       Int
  isSystem    Boolean  @default(false) @map("is_system")
  createdAt   DateTime @default(now()) @map("created_at")
  updatedAt   DateTime @updatedAt @map("updated_at")

  permissions RolePermission[]
  employees   Employee[]
  invitations Invitation[]

  @@map("roles")
}

model Permission {
  id          String  @id @default(uuid())
  module      String
  action      String
  description String?

  roles RolePermission[]

  @@unique([module, action])
  @@map("permissions")
}

model RolePermission {
  id           String @id @default(uuid())
  roleId       String @map("role_id")
  permissionId String @map("permission_id")
  scope        String

  role       Role       @relation(fields: [roleId], references: [id], onDelete: Cascade)
  permission Permission @relation(fields: [permissionId], references: [id], onDelete: Cascade)

  @@unique([roleId, permissionId])
  @@map("role_permissions")
}

model Invitation {
  id           String   @id @default(uuid())
  email        String   @unique
  roleId       String   @map("role_id")
  departmentId String?  @map("department_id")
  invitedById  String   @map("invited_by_id")
  status       String   @default("PENDING")
  token        String   @unique @default(uuid())
  expiresAt    DateTime @map("expires_at")
  employeeId   String?  @unique @map("employee_id")
  createdAt    DateTime @default(now()) @map("created_at")

  role       Role        @relation(fields: [roleId], references: [id])
  department Department? @relation(fields: [departmentId], references: [id])
  invitedBy  Employee    @relation("InvitedBy", fields: [invitedById], references: [id])
  employee   Employee?   @relation("InvitationEmployee", fields: [employeeId], references: [id])

  @@map("invitations")
}

// ─── EMPLOYEES & PARTNERS ─────────────────────────────────

enum EmployeeLevelEnum {
  JUNIOR
  MIDDLE
  SENIOR
  LEAD
  HEAD
}

enum EmployeeStatusEnum {
  ACTIVE
  PROBATION
  ON_LEAVE
  TERMINATED
}

model Employee {
  id           String               @id @default(uuid())
  passwordHash String?              @map("password_hash")
  firstName    String               @map("first_name")
  lastName     String               @map("last_name")
  email        String               @unique
  phone        String?
  telegram     String?
  avatar       String?
  birthday     DateTime?
  notes        String?
  position     String?
  roleId       String               @map("role_id")
  role         Role                 @relation(fields: [roleId], references: [id])
  departments  EmployeeDepartment[]
  level        EmployeeLevelEnum?
  baseSalary   Decimal?             @map("base_salary") @db.Decimal(12, 2)
  workSchedule Json?                @map("work_schedule")
  hireDate     DateTime?            @map("hire_date")
  fireDate     DateTime?            @map("fire_date")
  status       EmployeeStatusEnum   @default(PROBATION)
  createdAt    DateTime             @default(now()) @map("created_at")
  updatedAt    DateTime             @updatedAt @map("updated_at")

  productsManaging         Product[]               @relation("ProductPM")
  extensionsAssigned       Extension[]             @relation("ExtensionAssignee")
  leadsAssigned            Lead[]                  @relation("LeadAssignee")
  dealsSelling             Deal[]                  @relation("DealSeller")
  dealsAsSellerAssistant   Deal[]                  @relation("DealSellerAssistant")
  dealsPM                  Deal[]                  @relation("DealPM")
  paymentsConfirmed        Payment[]               @relation("PaymentConfirmer")
  tasksCreated             Task[]                  @relation("TaskCreator")
  tasksAssigned            Task[]                  @relation("TaskAssignee")
  ticketsAssigned          SupportTicket[]         @relation("TicketAssignee")
  bonusEntries             BonusEntry[]
  payrollRunsCreated       PayrollRun[]            @relation("PayrollRunCreator")
  payrollRunsApproved      PayrollRun[]            @relation("PayrollRunApprover")
  salaryLines              SalaryLine[]
  recurringTasksCreated    RecurringTaskTemplate[] @relation("RecurringTaskCreator")
  recurringTasksAssigned   RecurringTaskTemplate[] @relation("RecurringTaskAssignee")
  invitationsSent          Invitation[]            @relation("InvitedBy")
  invitationReceived       Invitation?             @relation("InvitationEmployee")
  credentialsOwned         Credential[]            @relation("CredentialOwner")
  marketingAccountsOwned   MarketingAccount[]      @relation("MarketingAccountOwner")
  marketingActivitiesOwned MarketingActivity[]     @relation("MarketingActivityOwner")

  messengerChannelMessagesSent MessengerChannelMessage[]           @relation("MessengerChannelMessageSender")
  messengerDirectMessagesSent  MessengerDirectMessage[]            @relation("MessengerDirectMessageSender")
  messengerChannelAttachments  MessengerChannelMessageAttachment[] @relation("MessengerChannelAttachmentActor")
  messengerDirectAttachments   MessengerDirectMessageAttachment[]  @relation("MessengerDirectAttachmentActor")
  messengerDmThreadsAsA        MessengerDirectThread[]             @relation("MessengerDmThreadParticipantA")
  messengerDmThreadsAsB        MessengerDirectThread[]             @relation("MessengerDmThreadParticipantB")
  messengerChannelReadStates   MessengerChannelReadState[]
  messengerDmThreadReadStates  MessengerDirectThreadReadState[]
  mailAccountsOwned            MailAccount[]                       @relation("MailAccountOwner")
  mailAccountsCreated          MailAccount[]                       @relation("MailAccountCreatedBy")
  mailDeliveryLogsActed        MailDeliveryLog[]                   @relation("MailDeliveryLogActor")
  inAppNotificationsReceived   InAppNotification[]
  dashboardPreference          DashboardPreference?
  reportExportJobsRequested    ReportExportJob[]
  reportSchedulesOwned         ReportSchedule[]
  savedReportViews             SavedReportView[]
  personalLinks                PersonalLink[]
  dashboardNotes               DashboardNote[]

  @@map("employees")
}

model DashboardPreference {
  id                   String   @id @default(uuid())
  employeeId           String   @unique @map("employee_id")
  pinnedActionOrder    String[] @map("pinned_action_order")
  hiddenPinnedActions  String[] @map("hidden_pinned_actions")
  visibleWidgets       String[] @map("visible_widgets")
  hiddenWidgets        String[] @map("hidden_widgets")
  compactWidgets       String[] @map("compact_widgets")
  defaultDashboardMode String   @default("control_center") @map("default_dashboard_mode")
  updatedAt            DateTime @updatedAt @map("updated_at")
  createdAt            DateTime @default(now()) @map("created_at")

  employee Employee @relation(fields: [employeeId], references: [id], onDelete: Cascade)

  @@map("dashboard_preferences")
}

model PersonalLink {
  id           String   @id @default(uuid())
  ownerId      String   @map("owner_id")
  label        String
  url          String
  placement    String[] @default(["SIDEBAR"])
  openInNewTab Boolean  @default(false) @map("open_in_new_tab")
  sortOrder    Int      @default(0) @map("sort_order")
  createdAt    DateTime @default(now()) @map("created_at")
  updatedAt    DateTime @updatedAt @map("updated_at")

  owner Employee @relation(fields: [ownerId], references: [id], onDelete: Cascade)

  @@index([ownerId, sortOrder])
  @@map("personal_links")
}

model DashboardNote {
  id        String   @id @default(uuid())
  ownerId   String   @map("owner_id")
  content   String
  sortOrder Int      @default(0) @map("sort_order")
  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  owner Employee @relation(fields: [ownerId], references: [id], onDelete: Cascade)

  @@index([ownerId, sortOrder])
  @@map("dashboard_notes")
}

enum PartnerTypeEnum {
  REGULAR
  PREMIUM
}

enum PartnerDirectionEnum {
  INBOUND
  OUTBOUND
  BOTH
}

enum PartnerStatusEnum {
  ACTIVE
  INACTIVE
}

model Partner {
  id             String               @id @default(uuid())
  name           String
  type           PartnerTypeEnum      @default(REGULAR)
  direction      PartnerDirectionEnum @default(INBOUND)
  defaultPercent Decimal              @default(30) @map("default_percent") @db.Decimal(5, 2)
  status         PartnerStatusEnum    @default(ACTIVE)
  contactId      String?              @map("contact_id")
  createdAt      DateTime             @default(now()) @map("created_at")
  updatedAt      DateTime             @updatedAt @map("updated_at")

  contact       Contact?       @relation(fields: [contactId], references: [id])
  orders        Order[]
  subscriptions Subscription[]
  leadsAsSource Lead[]         @relation("LeadSourcePartner")
  dealsAsSource Deal[]         @relation("DealSourcePartner")

  @@map("partners")
}

// ─── INTERNAL MESSENGER (MVP) ─────────────────────────────

enum MessengerChannelType {
  PROJECT
  GENERAL
  ANNOUNCEMENT
}

model MessengerChannel {
  id        String               @id @default(uuid())
  name      String
  projectId String               @map("project_id")
  type      MessengerChannelType
  createdAt DateTime             @default(now()) @map("created_at")

  messages   MessengerChannelMessage[]
  readStates MessengerChannelReadState[]

  @@map("messenger_channels")
}

model MessengerChannelMessage {
  id                 String           @id @default(uuid())
  channelId          String           @map("channel_id")
  channel            MessengerChannel @relation(fields: [channelId], references: [id], onDelete: Cascade)
  senderId           String           @map("sender_id")
  sender             Employee         @relation("MessengerChannelMessageSender", fields: [senderId], references: [id])
  senderNameSnapshot String           @map("sender_name_snapshot")
  content            String           @db.Text
  editedAt           DateTime?        @map("edited_at")
  createdAt          DateTime         @default(now()) @map("created_at")

  attachments MessengerChannelMessageAttachment[]

  @@index([channelId, createdAt])
  @@map("messenger_channel_messages")
}

model MessengerChannelMessageAttachment {
  id           String   @id @default(uuid())
  messageId    String   @map("message_id")
  fileAssetId  String   @map("file_asset_id")
  attachedById String?  @map("attached_by_id")
  createdAt    DateTime @default(now()) @map("created_at")

  message    MessengerChannelMessage @relation(fields: [messageId], references: [id], onDelete: Cascade)
  fileAsset  FileAsset               @relation(fields: [fileAssetId], references: [id])
  attachedBy Employee?               @relation("MessengerChannelAttachmentActor", fields: [attachedById], references: [id], onDelete: SetNull)

  @@index([messageId])
  @@index([fileAssetId])
  @@map("messenger_channel_message_attachments")
}

model MessengerChannelReadState {
  id         String   @id @default(uuid())
  channelId  String   @map("channel_id")
  employeeId String   @map("employee_id")
  lastReadAt DateTime @map("last_read_at")

  channel  MessengerChannel @relation(fields: [channelId], references: [id], onDelete: Cascade)
  employee Employee         @relation(fields: [employeeId], references: [id], onDelete: Cascade)

  @@unique([channelId, employeeId])
  @@index([employeeId])
  @@map("messenger_channel_read_states")
}

model MessengerDirectThread {
  id             String   @id @default(uuid())
  participantAId String   @map("participant_a_id")
  participantBId String   @map("participant_b_id")
  participantA   Employee @relation("MessengerDmThreadParticipantA", fields: [participantAId], references: [id])
  participantB   Employee @relation("MessengerDmThreadParticipantB", fields: [participantBId], references: [id])
  createdAt      DateTime @default(now()) @map("created_at")

  messages   MessengerDirectMessage[]
  readStates MessengerDirectThreadReadState[]

  @@unique([participantAId, participantBId])
  @@map("messenger_direct_threads")
}

model MessengerDirectMessage {
  id                 String                @id @default(uuid())
  threadId           String                @map("thread_id")
  thread             MessengerDirectThread @relation(fields: [threadId], references: [id], onDelete: Cascade)
  senderId           String                @map("sender_id")
  sender             Employee              @relation("MessengerDirectMessageSender", fields: [senderId], references: [id])
  senderNameSnapshot String                @map("sender_name_snapshot")
  content            String                @db.Text
  editedAt           DateTime?             @map("edited_at")
  createdAt          DateTime              @default(now()) @map("created_at")

  attachments MessengerDirectMessageAttachment[]

  @@index([threadId, createdAt])
  @@map("messenger_direct_messages")
}

model MessengerDirectMessageAttachment {
  id           String   @id @default(uuid())
  messageId    String   @map("message_id")
  fileAssetId  String   @map("file_asset_id")
  attachedById String?  @map("attached_by_id")
  createdAt    DateTime @default(now()) @map("created_at")

  message    MessengerDirectMessage @relation(fields: [messageId], references: [id], onDelete: Cascade)
  fileAsset  FileAsset              @relation(fields: [fileAssetId], references: [id])
  attachedBy Employee?              @relation("MessengerDirectAttachmentActor", fields: [attachedById], references: [id], onDelete: SetNull)

  @@index([messageId])
  @@index([fileAssetId])
  @@map("messenger_direct_message_attachments")
}

model MessengerDirectThreadReadState {
  id         String   @id @default(uuid())
  threadId   String   @map("thread_id")
  employeeId String   @map("employee_id")
  lastReadAt DateTime @map("last_read_at")

  thread   MessengerDirectThread @relation(fields: [threadId], references: [id], onDelete: Cascade)
  employee Employee              @relation(fields: [employeeId], references: [id], onDelete: Cascade)

  @@unique([threadId, employeeId])
  @@index([employeeId])
  @@map("messenger_direct_thread_read_states")
}

// ─── MAIL (MVP data foundation) ─────────────────────────────

enum MailProviderType {
  GMAIL
  CORPORATE_IMAP_SMTP
}

enum MailProviderConnectionStatus {
  NOT_CONNECTED
  CONNECTED
  DEGRADED
  NEEDS_RECONNECT
  PAUSED
}

enum MailAccountStatus {
  ACTIVE
  NEEDS_RECONNECT
  PAUSED
  DISABLED
  SYNCING
  DEGRADED
}

model MailAccount {
  id                  String            @id @default(uuid())
  ownerEmployeeId     String?           @map("owner_employee_id")
  emailAddress        String            @map("email_address")
  displayName         String?           @map("display_name")
  providerType        MailProviderType  @map("provider_type")
  status              MailAccountStatus @default(PAUSED)
  lastSyncAt          DateTime?         @map("last_sync_at")
  lastErrorAt         DateTime?         @map("last_error_at")
  createdByEmployeeId String?           @map("created_by_employee_id")
  createdAt           DateTime          @default(now()) @map("created_at")
  updatedAt           DateTime          @updatedAt @map("updated_at")

  owner              Employee?               @relation("MailAccountOwner", fields: [ownerEmployeeId], references: [id], onDelete: SetNull)
  createdBy          Employee?               @relation("MailAccountCreatedBy", fields: [createdByEmployeeId], references: [id], onDelete: SetNull)
  providerConnection MailProviderConnection?
  threads            EmailThread[]
  messages           EmailMessage[]
  deliveryLogs       MailDeliveryLog[]

  @@index([ownerEmployeeId])
  @@map("mail_accounts")
}

model MailProviderConnection {
  id                String                       @id @default(uuid())
  mailAccountId     String                       @unique @map("mail_account_id")
  providerType      MailProviderType             @map("provider_type")
  status            MailProviderConnectionStatus @default(NOT_CONNECTED)
  credentialId      String?                      @map("credential_id")
  providerAccountId String?                      @map("provider_account_id")
  username          String?
  imapHost          String?                      @map("imap_host")
  imapPort          Int?                         @map("imap_port")
  smtpHost          String?                      @map("smtp_host")
  smtpPort          Int?                         @map("smtp_port")
  secureMode        String?                      @map("secure_mode")
  grantedScopes     Json?                        @map("granted_scopes")
  syncCursor        String?                      @map("sync_cursor")
  lastValidatedAt   DateTime?                    @map("last_validated_at")
  lastErrorAt       DateTime?                    @map("last_error_at")
  lastErrorMessage  String?                      @map("last_error_message") @db.Text
  createdAt         DateTime                     @default(now()) @map("created_at")
  updatedAt         DateTime                     @updatedAt @map("updated_at")

  mailAccount MailAccount @relation(fields: [mailAccountId], references: [id], onDelete: Cascade)
  credential  Credential? @relation(fields: [credentialId], references: [id], onDelete: SetNull)

  @@index([providerType])
  @@index([status])
  @@index([credentialId])
  @@map("mail_provider_connections")
}

enum EmailThreadStatus {
  OPEN
  ARCHIVED
  CLOSED
}

model EmailThread {
  id                String            @id @default(uuid())
  mailAccountId     String            @map("mail_account_id")
  subjectNormalized String            @map("subject_normalized")
  lastMessageAt     DateTime          @map("last_message_at")
  lastInboundAt     DateTime?         @map("last_inbound_at")
  lastOutboundAt    DateTime?         @map("last_outbound_at")
  status            EmailThreadStatus @default(OPEN)
  hasUnread         Boolean           @default(true) @map("has_unread")
  needsBusinessLink Boolean           @default(false) @map("needs_business_link")
  createdAt         DateTime          @default(now()) @map("created_at")
  updatedAt         DateTime          @updatedAt @map("updated_at")

  mailAccount MailAccount    @relation(fields: [mailAccountId], references: [id], onDelete: Cascade)
  messages    EmailMessage[]

  @@index([mailAccountId, lastMessageAt])
  @@map("email_threads")
}

enum EmailMessageDirection {
  INBOUND
  OUTBOUND
}

enum EmailMessageReadState {
  UNREAD
  READ
}

enum EmailDeliveryStatus {
  DRAFT
  QUEUED
  SENT
  FAILED
  CANCELLED
}

enum MailDeliveryLogKind {
  OUTBOUND_DRAFT_SAVED
  OUTBOUND_QUEUED
  OUTBOUND_SEND_STUB_FAILED
  OUTBOUND_SEND_CANCELLED
  OUTBOUND_FAILED_RESET_TO_DRAFT
}

enum EmailAttachmentDownloadStatus {
  PENDING
  READY
  FAILED
}

model EmailMessage {
  id                String                @id @default(uuid())
  threadId          String                @map("thread_id")
  mailAccountId     String                @map("mail_account_id")
  providerMessageId String?               @map("provider_message_id")
  messageIdHeader   String?               @map("message_id_header")
  direction         EmailMessageDirection
  subject           String
  bodyText          String?               @map("body_text") @db.Text
  bodyHtmlSanitized String?               @map("body_html_sanitized") @db.Text
  sentAt            DateTime?             @map("sent_at")
  receivedAt        DateTime?             @map("received_at")
  readState         EmailMessageReadState @default(UNREAD) @map("read_state")
  deliveryStatus    EmailDeliveryStatus?  @map("delivery_status")
  createdAt         DateTime              @default(now()) @map("created_at")
  updatedAt         DateTime              @updatedAt @map("updated_at")

  thread       EmailThread       @relation(fields: [threadId], references: [id], onDelete: Cascade)
  mailAccount  MailAccount       @relation(fields: [mailAccountId], references: [id], onDelete: Cascade)
  recipients   EmailRecipient[]
  deliveryLogs MailDeliveryLog[]
  attachments  EmailAttachment[]

  @@index([threadId, receivedAt])
  @@map("email_messages")
}

model EmailAttachment {
  id                   String                        @id @default(uuid())
  messageId            String                        @map("message_id")
  fileAssetId          String                        @map("file_asset_id")
  fileName             String                        @map("file_name")
  mimeType             String?                       @map("mime_type")
  sizeBytes            BigInt?                       @map("size_bytes")
  providerAttachmentId String?                       @map("provider_attachment_id")
  isInline             Boolean                       @default(false) @map("is_inline")
  downloadStatus       EmailAttachmentDownloadStatus @default(READY) @map("download_status")
  createdAt            DateTime                      @default(now()) @map("created_at")

  message   EmailMessage @relation(fields: [messageId], references: [id], onDelete: Cascade)
  fileAsset FileAsset    @relation(fields: [fileAssetId], references: [id], onDelete: Restrict)

  @@index([messageId])
  @@index([fileAssetId])
  @@index([downloadStatus])
  @@map("email_attachments")
}

model MailDeliveryLog {
  id              String              @id @default(uuid())
  emailMessageId  String              @map("email_message_id")
  mailAccountId   String              @map("mail_account_id")
  actorEmployeeId String              @map("actor_employee_id")
  kind            MailDeliveryLogKind
  detail          String?             @db.Text
  createdAt       DateTime            @default(now()) @map("created_at")

  message     EmailMessage @relation(fields: [emailMessageId], references: [id], onDelete: Cascade)
  mailAccount MailAccount  @relation(fields: [mailAccountId], references: [id], onDelete: Cascade)
  actor       Employee     @relation("MailDeliveryLogActor", fields: [actorEmployeeId], references: [id], onDelete: Restrict)

  @@index([emailMessageId, createdAt])
  @@index([mailAccountId, createdAt])
  @@map("mail_delivery_logs")
}

enum EmailRecipientKind {
  FROM
  TO
  CC
  BCC
  REPLY_TO
}

model EmailRecipient {
  id          String             @id @default(uuid())
  messageId   String             @map("message_id")
  kind        EmailRecipientKind
  email       String
  displayName String?            @map("display_name")
  createdAt   DateTime           @default(now()) @map("created_at")

  message EmailMessage @relation(fields: [messageId], references: [id], onDelete: Cascade)

  @@index([messageId])
  @@map("email_recipients")
}

// ─── IN-APP NOTIFICATIONS ───────────────────────────────────

model InAppNotification {
  id                  String    @id @default(uuid())
  recipientEmployeeId String    @map("recipient_employee_id")
  type                String
  category            String    @default("informational")
  priority            String    @default("normal")
  title               String
  body                String    @db.Text
  link                String?
  actionLabel         String?   @map("action_label")
  entityType          String?   @map("entity_type")
  entityId            String?   @map("entity_id")
  isRead              Boolean   @default(false) @map("is_read")
  readAt              DateTime? @map("read_at")
  archivedAt          DateTime? @map("archived_at")
  createdAt           DateTime  @default(now()) @map("created_at")

  recipient Employee @relation(fields: [recipientEmployeeId], references: [id], onDelete: Cascade)

  @@index([recipientEmployeeId, createdAt])
  @@index([recipientEmployeeId, isRead])
  @@index([recipientEmployeeId, archivedAt])
  @@index([category])
  @@index([priority])
  @@map("in_app_notifications")
}

enum NotificationJobStatus {
  PENDING
  PROCESSING
  DELIVERED
  FAILED
  CANCELLED
}

enum NotificationDeliveryChannel {
  IN_APP
  TELEGRAM
  WHATSAPP
  EMAIL
}

enum NotificationDeliveryStatus {
  PENDING
  DELIVERED
  FAILED
  SKIPPED
}

model NotificationEvent {
  id               String   @id @default(uuid())
  eventType        String   @map("event_type")
  sourceModule     String   @map("source_module")
  sourceEntityType String?  @map("source_entity_type")
  sourceEntityId   String?  @map("source_entity_id")
  payload          Json?
  occurredAt       DateTime @default(now()) @map("occurred_at")
  idempotencyKey   String   @unique @map("idempotency_key")
  createdAt        DateTime @default(now()) @map("created_at")

  jobs NotificationJob[]

  @@index([eventType])
  @@index([sourceModule])
  @@index([sourceEntityType, sourceEntityId])
  @@map("notification_events")
}

model NotificationRule {
  id                String   @id @default(uuid())
  code              String   @unique
  eventType         String   @map("event_type")
  recipientResolver String   @default("ACTOR") @map("recipient_resolver")
  channels          String[] @default(["IN_APP"])
  priority          String   @default("normal")
  enabled           Boolean  @default(true)
  createdAt         DateTime @default(now()) @map("created_at")
  updatedAt         DateTime @updatedAt @map("updated_at")

  jobs NotificationJob[]

  @@index([eventType])
  @@index([enabled])
  @@map("notification_rules")
}

model NotificationJob {
  id           String                @id @default(uuid())
  eventId      String                @map("event_id")
  ruleId       String                @map("rule_id")
  status       NotificationJobStatus @default(PENDING)
  scheduledFor DateTime              @default(now()) @map("scheduled_for")
  attemptCount Int                   @default(0) @map("attempt_count")
  nextRetryAt  DateTime?             @map("next_retry_at")
  dedupeKey    String                @unique @map("dedupe_key")
  createdAt    DateTime              @default(now()) @map("created_at")
  processedAt  DateTime?             @map("processed_at")

  event      NotificationEvent      @relation(fields: [eventId], references: [id], onDelete: Cascade)
  rule       NotificationRule       @relation(fields: [ruleId], references: [id], onDelete: Restrict)
  deliveries NotificationDelivery[]

  @@index([eventId])
  @@index([ruleId])
  @@index([status])
  @@index([scheduledFor])
  @@map("notification_jobs")
}

model NotificationDelivery {
  id                String                      @id @default(uuid())
  jobId             String                      @map("job_id")
  channel           NotificationDeliveryChannel
  recipient         String
  status            NotificationDeliveryStatus  @default(PENDING)
  provider          String?
  providerMessageId String?                     @map("provider_message_id")
  errorCode         String?                     @map("error_code")
  errorMessage      String?                     @map("error_message") @db.Text
  sentAt            DateTime?                   @map("sent_at")
  deliveredAt       DateTime?                   @map("delivered_at")
  readAt            DateTime?                   @map("read_at")
  createdAt         DateTime                    @default(now()) @map("created_at")

  job NotificationJob @relation(fields: [jobId], references: [id], onDelete: Cascade)

  @@index([jobId])
  @@index([channel])
  @@index([status])
  @@map("notification_deliveries")
}

// ─── TECHNICAL INFRASTRUCTURE ─────────────────────────────

enum TechnicalHealthStatus {
  HEALTHY
  WARNING
  CRITICAL
  NOT_CONFIGURED
  UNKNOWN
}

enum TechnicalBackupStatus {
  HEALTHY
  WARNING
  MISSING
  NOT_REQUIRED
  UNKNOWN
}

enum TechnicalDeployStatus {
  SUCCESS
  FAILED
  ROLLED_BACK
  UNKNOWN
}

enum TechnicalAssetType {
  DOMAIN
  HOSTING
  REPOSITORY
  DATABASE
  STORAGE
  MONITORING
  ERROR_TRACKING
  EXTERNAL_API
  QUEUE
  OTHER
}

enum TechnicalAssetStatus {
  ACTIVE
  WARNING
  BROKEN
  DEPRECATED
  UNKNOWN
}

enum TechnicalEnvironmentKind {
  PRODUCTION
  STAGING
  DEVELOPMENT
  PREVIEW
  LEGACY
}

model ProductTechnicalProfile {
  id               String                @id @default(uuid())
  productId        String                @unique @map("product_id")
  projectId        String                @map("project_id")
  technicalOwnerId String?               @map("technical_owner_id")
  productionUrl    String?               @map("production_url")
  stagingUrl       String?               @map("staging_url")
  repositoryUrl    String?               @map("repository_url")
  deploymentMethod String?               @map("deployment_method")
  hostingProvider  String?               @map("hosting_provider")
  monitoringStatus TechnicalHealthStatus @default(NOT_CONFIGURED) @map("monitoring_status")
  backupStatus     TechnicalBackupStatus @default(UNKNOWN) @map("backup_status")
  lastDeployAt     DateTime?             @map("last_deploy_at")
  lastDeployStatus TechnicalDeployStatus @default(UNKNOWN) @map("last_deploy_status")
  technicalNotes   String?               @map("technical_notes") @db.Text
  createdAt        DateTime              @default(now()) @map("created_at")
  updatedAt        DateTime              @updatedAt @map("updated_at")

  product Product @relation(fields: [productId], references: [id], onDelete: Cascade)
  project Project @relation(fields: [projectId], references: [id], onDelete: Cascade)

  @@index([projectId])
  @@index([technicalOwnerId])
  @@map("product_technical_profiles")
}

model TechnicalAsset {
  id                    String                    @id @default(uuid())
  productId             String                    @map("product_id")
  projectId             String                    @map("project_id")
  type                  TechnicalAssetType
  name                  String
  provider              String?
  environment           TechnicalEnvironmentKind?
  status                TechnicalAssetStatus      @default(UNKNOWN)
  url                   String?
  ownerId               String?                   @map("owner_id")
  credentialId          String?                   @map("credential_id")
  clientServiceRecordId String?                   @map("client_service_record_id")
  notes                 String?                   @db.Text
  createdAt             DateTime                  @default(now()) @map("created_at")
  updatedAt             DateTime                  @updatedAt @map("updated_at")

  product Product @relation(fields: [productId], references: [id], onDelete: Cascade)
  project Project @relation(fields: [projectId], references: [id], onDelete: Cascade)

  @@index([productId])
  @@index([projectId])
  @@index([type])
  @@index([status])
  @@map("technical_assets")
}

model TechnicalEnvironment {
  id               String                   @id @default(uuid())
  productId        String                   @map("product_id")
  projectId        String                   @map("project_id")
  kind             TechnicalEnvironmentKind
  name             String
  url              String?
  branch           String?
  deploymentTarget String?                  @map("deployment_target")
  envCredentialId  String?                  @map("env_credential_id")
  databaseAssetId  String?                  @map("database_asset_id")
  status           TechnicalHealthStatus    @default(UNKNOWN)
  lastCheckedAt    DateTime?                @map("last_checked_at")
  createdAt        DateTime                 @default(now()) @map("created_at")
  updatedAt        DateTime                 @updatedAt @map("updated_at")

  product Product @relation(fields: [productId], references: [id], onDelete: Cascade)
  project Project @relation(fields: [projectId], references: [id], onDelete: Cascade)

  @@index([productId])
  @@index([projectId])
  @@index([kind])
  @@index([status])
  @@map("technical_environments")
}

// ─── CALENDAR ─────────────────────────────────────────────

enum CalendarMeetingType {
  SALES_CALL
  OFFER_PRESENTATION
  DEMO
  KICKOFF
  SUPPORT_CALL
  MAINTENANCE_CALL
  OTHER
}

enum CalendarLocationType {
  ONLINE
  OFFLINE
}

enum CalendarMeetingStatus {
  SCHEDULED
  COMPLETED
  CANCELLED
  NO_SHOW
}

enum PersonalCalendarEventStatus {
  ACTIVE
  CANCELLED
}

model CalendarMeeting {
  id                     String                @id @default(uuid())
  title                  String
  startsAt               DateTime              @map("starts_at")
  endsAt                 DateTime              @map("ends_at")
  meetingType            CalendarMeetingType   @map("meeting_type")
  locationType           CalendarLocationType  @map("location_type")
  locationOrLink         String?               @map("location_or_link")
  agenda                 String?
  outcomeNotes           String?               @map("outcome_notes")
  status                 CalendarMeetingStatus @default(SCHEDULED)
  internalParticipantIds String[]              @default([]) @map("internal_participant_ids")
  externalParticipants   Json?                 @map("external_participants")
  projectId              String?               @map("project_id")
  productId              String?               @map("product_id")
  dealId                 String?               @map("deal_id")
  contactId              String?               @map("contact_id")
  createdById            String                @map("created_by_id")
  createdAt              DateTime              @default(now()) @map("created_at")
  updatedAt              DateTime              @updatedAt @map("updated_at")

  @@index([startsAt])
  @@index([endsAt])
  @@index([status])
  @@index([createdById])
  @@index([projectId])
  @@index([productId])
  @@index([dealId])
  @@map("calendar_meetings")
}

model PersonalCalendarEvent {
  id        String                      @id @default(uuid())
  ownerId   String                      @map("owner_id")
  title     String
  startsAt  DateTime                    @map("starts_at")
  endsAt    DateTime                    @map("ends_at")
  isAllDay  Boolean                     @default(false) @map("is_all_day")
  notes     String?
  status    PersonalCalendarEventStatus @default(ACTIVE)
  createdAt DateTime                    @default(now()) @map("created_at")
  updatedAt DateTime                    @updatedAt @map("updated_at")

  @@index([ownerId])
  @@index([startsAt])
  @@index([endsAt])
  @@index([status])
  @@map("personal_calendar_events")
}

// ─── AUDIT ────────────────────────────────────────────────

model AuditLog {
  id         String   @id @default(uuid())
  projectId  String?  @map("project_id")
  entityType String   @map("entity_type")
  entityId   String   @map("entity_id")
  action     String
  userId     String   @map("user_id")
  changes    Json?
  ipAddress  String?  @map("ip_address")
  createdAt  DateTime @default(now()) @map("created_at")

  project Project? @relation(fields: [projectId], references: [id])

  @@index([entityType, entityId])
  @@index([userId])
  @@index([createdAt])
  @@map("audit_logs")
}

// ─── SYSTEM LISTS (reference data: product types, deal types, etc.) ───

model SystemListOption {
  id        String   @id @default(uuid())
  listKey   String   @map("list_key")
  code      String
  label     String
  sortOrder Int      @default(0) @map("sort_order")
  isActive  Boolean  @default(true) @map("is_active")
  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  @@unique([listKey, code])
  @@index([listKey])
  @@map("system_list_options")
}
