generator client {
  provider = "prisma-client"
  output   = "../src/generated/prisma"
}

datasource db {
  provider = "postgresql"
}

// ─── CONTACT & COMPANY ────────────────────────────────────

enum ContactRole {
  CLIENT
  PARTNER
  CONTRACTOR
  OTHER
}

model Contact {
  id             String      @id @default(uuid())
  firstName      String      @map("first_name")
  lastName       String      @map("last_name")
  phone          String?
  email          String?
  messengerLinks Json?       @map("messenger_links")
  role           ContactRole @default(CLIENT)
  notes          String?
  createdAt      DateTime    @default(now()) @map("created_at")
  updatedAt      DateTime    @updatedAt @map("updated_at")

  companies          Company[]
  projects           Project[]
  leads              Lead[]
  deals              Deal[]
  tickets            SupportTicket[]
  leadsAsSource      Lead[]          @relation("LeadSourceContact")
  dealsAsSource      Deal[]          @relation("DealSourceContact")

  @@map("contacts")
}

enum CompanyType {
  LEGAL
  INDIVIDUAL
  SOLE_PROPRIETOR
}

enum TaxStatus {
  TAX
  TAX_FREE
}

model Company {
  id           String      @id @default(uuid())
  name         String
  type         CompanyType @default(LEGAL)
  taxId        String?     @map("tax_id")
  legalAddress String?     @map("legal_address")
  bankDetails  Json?       @map("bank_details")
  taxStatus    TaxStatus   @default(TAX)
  contactId    String      @map("contact_id")
  notes        String?
  createdAt    DateTime    @default(now()) @map("created_at")
  updatedAt    DateTime    @updatedAt @map("updated_at")

  contact  Contact   @relation(fields: [contactId], references: [id])
  projects Project[]
  invoices Invoice[]
  deals    Deal[]

  @@map("companies")
}

// ─── PROJECT ──────────────────────────────────────────────

enum ProjectType {
  WHITE_LABEL
  MIX
  CUSTOM_CODE
}

model Project {
  id          String      @id @default(uuid())
  code        String      @unique
  name        String
  contactId   String      @map("contact_id")
  companyId   String?     @map("company_id")
  type        ProjectType @default(CUSTOM_CODE)
  sellerId    String?     @map("seller_id")
  pmId        String?     @map("pm_id")
  deadline    DateTime?
  description String?
  isArchived  Boolean     @default(false) @map("is_archived")
  createdAt   DateTime    @default(now()) @map("created_at")
  updatedAt   DateTime    @updatedAt @map("updated_at")

  contact       Contact        @relation(fields: [contactId], references: [id])
  company       Company?       @relation(fields: [companyId], references: [id])
  seller        Employee?      @relation("ProjectSeller", fields: [sellerId], references: [id])
  pm            Employee?      @relation("ProjectPM", fields: [pmId], references: [id])
  orders        Order[]
  subscriptions Subscription[]
  credentials   Credential[]
  domains       Domain[]
  tickets       SupportTicket[]
  expenses      Expense[]
  bonusEntries  BonusEntry[]
  auditLogs     AuditLog[]

  @@map("projects")
}

// ─── CRM ──────────────────────────────────────────────────

enum LeadStatusEnum {
  NEW
  DIDNT_GET_THROUGH
  CONTACT_ESTABLISHED
  MQL
  SPAM
  SQL
}

enum LeadSourceEnum {
  MARKETING
  SALES
  PARTNER
  CLIENT
}

model Lead {
  id               String         @id @default(uuid())
  code             String         @unique
  name             String?
  contactName      String         @map("contact_name")
  phone            String?
  email            String?
  source           LeadSourceEnum
  sourceDetail     String?        @map("source_detail")
  sourcePartnerId  String?        @map("source_partner_id")
  sourceContactId  String?        @map("source_contact_id")
  status           LeadStatusEnum @default(NEW)
  assignedTo       String?        @map("assigned_to")
  contactId        String?        @map("contact_id")
  notes            String?
  createdAt        DateTime       @default(now()) @map("created_at")
  updatedAt        DateTime       @updatedAt @map("updated_at")

  contact       Contact?  @relation(fields: [contactId], references: [id])
  assignee      Employee? @relation("LeadAssignee", fields: [assignedTo], references: [id])
  sourcePartner Partner?  @relation("LeadSourcePartner", fields: [sourcePartnerId], references: [id])
  sourceContact Contact?  @relation("LeadSourceContact", fields: [sourceContactId], references: [id])
  deal          Deal?

  @@map("leads")
}

enum DealStatusEnum {
  START_CONVERSATION
  DISCUSS_NEEDS
  MEETING
  CAN_WE_DO_IT
  SEND_OFFER
  GET_ANSWER
  DEPOSIT_AND_CONTRACT
  CREATING
  GET_FINAL_PAY
  MAINTENANCE_OFFER
  FAILED
  WON
}

enum DealTypeEnum {
  NEW_CLIENT
  EXTENSION
  UPSELL
}

model Deal {
  id               String          @id @default(uuid())
  code             String          @unique
  name             String?
  leadId           String?         @unique @map("lead_id")
  contactId        String            @map("contact_id")
  projectId        String?           @map("project_id")
  companyId        String?           @map("company_id")
  type             DealTypeEnum
  status           DealStatusEnum    @default(START_CONVERSATION)
  amount           Decimal?          @db.Decimal(12, 2)
  paymentType      PaymentTypeEnum?  @map("payment_type")
  taxStatus        TaxStatus         @default(TAX) @map("tax_status")
  sellerId         String            @map("seller_id")
  source           LeadSourceEnum?
  sourceDetail     String?           @map("source_detail")
  sourcePartnerId  String?           @map("source_partner_id")
  sourceContactId  String?           @map("source_contact_id")
  notes            String?
  productType      String?           @map("product_type")
  pmId             String?           @map("pm_id")
  deadline         DateTime?
  createdAt        DateTime          @default(now()) @map("created_at")
  updatedAt        DateTime          @updatedAt @map("updated_at")

  lead          Lead?    @relation(fields: [leadId], references: [id])
  contact       Contact  @relation(fields: [contactId], references: [id])
  company       Company? @relation(fields: [companyId], references: [id])
  seller        Employee @relation("DealSeller", fields: [sellerId], references: [id])
  pm            Employee? @relation("DealPM", fields: [pmId], references: [id])
  sourcePartner Partner? @relation("DealSourcePartner", fields: [sourcePartnerId], references: [id])
  sourceContact Contact? @relation("DealSourceContact", fields: [sourceContactId], references: [id])
  orders        Order[]

  @@map("deals")
}

// ─── FINANCE ──────────────────────────────────────────────

enum OrderTypeEnum {
  PRODUCT
  EXTENSION
  SUBSCRIPTION
}

enum PaymentTypeEnum {
  CLASSIC
  SUBSCRIPTION
}

enum OrderStatusEnum {
  ACTIVE
  PARTIALLY_PAID
  FULLY_PAID
  CLOSED
}

model Order {
  id                   String           @id @default(uuid())
  code                 String           @unique
  projectId            String           @map("project_id")
  dealId               String?          @map("deal_id")
  type                 OrderTypeEnum
  paymentType          PaymentTypeEnum  @map("payment_type")
  totalAmount          Decimal          @map("total_amount") @db.Decimal(12, 2)
  currency             String           @default("AMD")
  taxStatus            TaxStatus        @default(TAX) @map("tax_status")
  status               OrderStatusEnum  @default(ACTIVE)
  partnerId            String?          @map("partner_id")
  partnerPercent       Decimal?         @default(30) @map("partner_percent") @db.Decimal(5, 2)
  sellerBonusPercent   Decimal?         @map("seller_bonus_percent") @db.Decimal(5, 2)
  deliveryBonusPercent Decimal?         @map("delivery_bonus_percent") @db.Decimal(5, 2)
  sellerBonusSource    LeadSourceEnum?  @map("seller_bonus_source")
  createdAt            DateTime         @default(now()) @map("created_at")
  updatedAt            DateTime         @updatedAt @map("updated_at")

  project      Project      @relation(fields: [projectId], references: [id])
  deal         Deal?        @relation(fields: [dealId], references: [id])
  partner      Partner?     @relation(fields: [partnerId], references: [id])
  invoices     Invoice[]
  bonusEntries BonusEntry[]

  @@map("orders")
}

enum InvoiceTypeEnum {
  DEVELOPMENT
  EXTENSION
  SUBSCRIPTION
  DOMAIN
  SERVICE
}

enum InvoiceStatusEnum {
  THIS_MONTH
  CREATE_INVOICE
  WAITING
  DELAYED
  ON_HOLD
  FAIL
  PAID
}

model Invoice {
  id             String            @id @default(uuid())
  code           String            @unique
  orderId        String?           @map("order_id")
  subscriptionId String?           @map("subscription_id")
  projectId      String            @map("project_id")
  companyId      String?           @map("company_id")
  amount         Decimal           @db.Decimal(12, 2)
  taxStatus      TaxStatus         @default(TAX) @map("tax_status")
  type           InvoiceTypeEnum
  status         InvoiceStatusEnum @default(THIS_MONTH)
  dueDate        DateTime?         @map("due_date")
  paidDate       DateTime?         @map("paid_date")
  govInvoiceId   String?           @map("gov_invoice_id")
  paymentLink    String?           @map("payment_link")
  createdAt      DateTime          @default(now()) @map("created_at")
  updatedAt      DateTime          @updatedAt @map("updated_at")

  order        Order?       @relation(fields: [orderId], references: [id])
  subscription Subscription? @relation(fields: [subscriptionId], references: [id])
  company      Company?     @relation(fields: [companyId], references: [id])
  payments     Payment[]

  @@map("invoices")
}

model Payment {
  id            String   @id @default(uuid())
  invoiceId     String   @map("invoice_id")
  amount        Decimal  @db.Decimal(12, 2)
  paymentDate   DateTime @map("payment_date")
  paymentMethod String?  @map("payment_method")
  confirmedBy   String?  @map("confirmed_by")
  notes         String?
  createdAt     DateTime @default(now()) @map("created_at")
  updatedAt     DateTime @updatedAt @map("updated_at")

  invoice   Invoice   @relation(fields: [invoiceId], references: [id])
  confirmer Employee? @relation("PaymentConfirmer", fields: [confirmedBy], references: [id])

  @@map("payments")
}

enum SubscriptionTypeEnum {
  MAINTENANCE_ONLY
  DEV_AND_MAINTENANCE
  DEV_ONLY
  PARTNER_SERVICE
}

enum SubscriptionStatusEnum {
  ACTIVE
  PAUSED
  CANCELLED
}

model Subscription {
  id         String                 @id @default(uuid())
  code       String                 @unique
  projectId  String                 @map("project_id")
  type       SubscriptionTypeEnum
  amount     Decimal                @db.Decimal(12, 2)
  billingDay Int                    @map("billing_day")
  taxStatus  TaxStatus              @default(TAX) @map("tax_status")
  startDate  DateTime               @map("start_date")
  endDate    DateTime?              @map("end_date")
  status     SubscriptionStatusEnum @default(ACTIVE)
  partnerId  String?                @map("partner_id")
  createdAt  DateTime               @default(now()) @map("created_at")
  updatedAt  DateTime               @updatedAt @map("updated_at")

  project  Project   @relation(fields: [projectId], references: [id])
  partner  Partner?  @relation(fields: [partnerId], references: [id])
  invoices Invoice[]

  @@map("subscriptions")
}

enum ExpenseTypeEnum {
  PLANNED
  UNPLANNED
}

enum ExpenseCategoryEnum {
  DOMAIN
  HOSTING
  SERVICE
  MARKETING
  SALARY
  BONUS
  PARTNER_PAYOUT
  TOOLS
  OTHER
}

enum ExpenseFrequency {
  ONE_TIME
  MONTHLY
  QUARTERLY
  YEARLY
  MULTI_YEAR
}

enum ExpenseStatusEnum {
  THIS_MONTH
  PAY_NOW
  DELAYED
  ON_HOLD
  PAID
  UNPAID
}

model Expense {
  id            String              @id @default(uuid())
  type          ExpenseTypeEnum
  category      ExpenseCategoryEnum
  name          String
  amount        Decimal             @db.Decimal(12, 2)
  frequency     ExpenseFrequency    @default(ONE_TIME)
  dueDate       DateTime?           @map("due_date")
  status        ExpenseStatusEnum   @default(THIS_MONTH)
  projectId     String?             @map("project_id")
  isPassThrough Boolean             @default(false) @map("is_pass_through")
  taxStatus     TaxStatus           @default(TAX) @map("tax_status")
  notes         String?
  createdAt     DateTime            @default(now()) @map("created_at")
  updatedAt     DateTime            @updatedAt @map("updated_at")

  project Project? @relation(fields: [projectId], references: [id])

  @@map("expenses")
}

enum BonusTypeEnum {
  SALES
  DELIVERY
  PM
  DESIGN
  MARKETING
}

enum BonusStatusEnum {
  INCOMING
  EARNED
  PENDING_ELIGIBILITY
  VESTED
  HOLDBACK
  ACTIVE
  PAID
  CLAWBACK
}

model BonusEntry {
  id                 String          @id @default(uuid())
  employeeId         String          @map("employee_id")
  orderId            String          @map("order_id")
  projectId          String          @map("project_id")
  type               BonusTypeEnum
  amount             Decimal         @db.Decimal(12, 2)
  percent            Decimal         @db.Decimal(5, 2)
  status             BonusStatusEnum @default(INCOMING)
  kpiGatePassed      Boolean?        @map("kpi_gate_passed")
  holdbackPercent    Decimal?        @default(20) @map("holdback_percent") @db.Decimal(5, 2)
  holdbackReleaseDate DateTime?      @map("holdback_release_date")
  payoutMonth        DateTime?       @map("payout_month")
  createdAt          DateTime        @default(now()) @map("created_at")
  updatedAt          DateTime        @updatedAt @map("updated_at")

  employee Employee @relation(fields: [employeeId], references: [id])
  order    Order    @relation(fields: [orderId], references: [id])
  project  Project  @relation(fields: [projectId], references: [id])

  @@map("bonus_entries")
}

// ─── TASKS ────────────────────────────────────────────────

enum TaskStatusEnum {
  NEW
  IN_PROGRESS
  DONE
  DEFERRED
  CANCELLED
}

enum TaskPriorityEnum {
  CRITICAL
  HIGH
  NORMAL
  LOW
}

model Task {
  id              String           @id @default(uuid())
  code            String           @unique
  title           String
  description     String?
  creatorId       String           @map("creator_id")
  assigneeId      String?          @map("assignee_id")
  coAssignees     String[]         @map("co_assignees")
  observers       String[]
  status          TaskStatusEnum   @default(NEW)
  priority        TaskPriorityEnum @default(NORMAL)
  startDate       DateTime?        @map("start_date")
  dueDate         DateTime?        @map("due_date")
  completedAt     DateTime?        @map("completed_at")
  parentId        String?          @map("parent_id")
  kanbanStageId   String?          @map("kanban_stage_id")
  myPlanStageId   String?          @map("my_plan_stage_id")
  myPlanSortOrder Int              @default(0) @map("my_plan_sort_order")
  chatId          String?          @unique @map("chat_id")
  isRecurring     Boolean          @default(false) @map("is_recurring")
  templateTaskId  String?          @map("template_task_id")
  createdAt       DateTime         @default(now()) @map("created_at")
  updatedAt       DateTime         @updatedAt @map("updated_at")

  creator    Employee        @relation("TaskCreator", fields: [creatorId], references: [id])
  assignee   Employee?       @relation("TaskAssignee", fields: [assigneeId], references: [id])
  parent     Task?           @relation("TaskSubtasks", fields: [parentId], references: [id])
  subtasks   Task[]          @relation("TaskSubtasks")
  links      TaskLink[]
  checklists TaskChecklist[]

  @@map("tasks")
}

model TaskLink {
  id         String   @id @default(uuid())
  taskId     String   @map("task_id")
  entityType String   @map("entity_type")
  entityId   String   @map("entity_id")
  createdAt  DateTime @default(now()) @map("created_at")

  task Task @relation(fields: [taskId], references: [id], onDelete: Cascade)

  @@unique([taskId, entityType, entityId])
  @@index([entityType, entityId])
  @@map("task_links")
}

model TaskChecklist {
  id        String   @id @default(uuid())
  taskId    String   @map("task_id")
  title     String   @default("Checklist")
  createdAt DateTime @default(now()) @map("created_at")

  task  Task                @relation(fields: [taskId], references: [id], onDelete: Cascade)
  items TaskChecklistItem[]

  @@map("task_checklists")
}

model TaskChecklistItem {
  id          String  @id @default(uuid())
  checklistId String  @map("checklist_id")
  text        String
  checked     Boolean @default(false)
  sortOrder   Int     @default(0) @map("sort_order")

  checklist TaskChecklist @relation(fields: [checklistId], references: [id], onDelete: Cascade)

  @@map("task_checklist_items")
}

model TaskBoardStage {
  id        String   @id @default(uuid())
  ownerId   String?  @map("owner_id")
  boardType String   @map("board_type")
  title     String
  color     String   @default("#3B82F6")
  sortOrder Int      @default(0) @map("sort_order")
  isDefault Boolean  @default(false) @map("is_default")
  createdAt DateTime @default(now()) @map("created_at")

  @@unique([ownerId, boardType, title])
  @@index([ownerId, boardType])
  @@map("task_board_stages")
}

model RecurringTaskTemplate {
  id            String           @id @default(uuid())
  title         String
  description   String?
  assigneeId    String?          @map("assignee_id")
  creatorId     String           @map("creator_id")
  priority      TaskPriorityEnum @default(NORMAL)
  frequency     String
  interval      Int              @default(1)
  daysOfWeek    String[]         @map("days_of_week")
  dayOfMonth    Int?             @map("day_of_month")
  startDate     DateTime         @map("start_date")
  endDate       DateTime?        @map("end_date")
  dueDateOffset Int?             @map("due_date_offset")
  isActive      Boolean          @default(true) @map("is_active")
  lastCreatedAt DateTime?        @map("last_created_at")
  nextCreateAt  DateTime?        @map("next_create_at")
  checklistData Json?            @map("checklist_data")
  linksData     Json?            @map("links_data")
  createdAt     DateTime         @default(now()) @map("created_at")
  updatedAt     DateTime         @updatedAt @map("updated_at")

  creator  Employee  @relation("RecurringTaskCreator", fields: [creatorId], references: [id])
  assignee Employee? @relation("RecurringTaskAssignee", fields: [assigneeId], references: [id])

  @@map("recurring_task_templates")
}

// ─── SUPPORT ──────────────────────────────────────────────

enum TicketCategoryEnum {
  INCIDENT
  SERVICE_REQUEST
  CHANGE_REQUEST
  PROBLEM
}

enum TicketPriorityEnum {
  P1
  P2
  P3
}

enum TicketStatusEnum {
  NEW
  TRIAGED
  ASSIGNED
  IN_PROGRESS
  RESOLVED
  CLOSED
  REOPENED
}

model SupportTicket {
  id                  String              @id @default(uuid())
  code                String              @unique
  projectId           String              @map("project_id")
  contactId           String?             @map("contact_id")
  category            TicketCategoryEnum
  priority            TicketPriorityEnum  @default(P3)
  status              TicketStatusEnum    @default(NEW)
  title               String
  description         String?
  billable            Boolean             @default(false)
  assignedTo          String?             @map("assigned_to")
  slaResponseDeadline DateTime?           @map("sla_response_deadline")
  slaResolveDeadline  DateTime?           @map("sla_resolve_deadline")
  createdAt           DateTime            @default(now()) @map("created_at")
  updatedAt           DateTime            @updatedAt @map("updated_at")

  project  Project   @relation(fields: [projectId], references: [id])
  contact  Contact?  @relation(fields: [contactId], references: [id])
  assignee Employee? @relation("TicketAssignee", fields: [assignedTo], references: [id])

  @@map("support_tickets")
}

// ─── CREDENTIALS & DOMAINS ────────────────────────────────

enum CredentialCategoryEnum {
  ADMIN
  DOMAIN
  HOSTING
  SERVICE
  APP
  MAIL
  API_KEY
  DATABASE
  OTHER
}

enum CredentialAccessLevelEnum {
  SECRET
  PROJECT_TEAM
  DEPARTMENT
  ALL
  PERSONAL
}

model Credential {
  id               String                    @id @default(uuid())
  projectId        String?                   @map("project_id")
  departmentId     String?                   @map("department_id")
  ownerId          String?                   @map("owner_id")
  category         CredentialCategoryEnum
  provider         String?
  name             String
  url              String?
  login            String?
  password         String?
  apiKey           String?                   @map("api_key")
  envData          String?                   @map("env_data")
  phone            String?
  notes            String?
  accessLevel      CredentialAccessLevelEnum  @default(PROJECT_TEAM) @map("access_level")
  allowedEmployees String[]                  @map("allowed_employees")
  createdAt        DateTime                  @default(now()) @map("created_at")
  updatedAt        DateTime                  @updatedAt @map("updated_at")

  project    Project?    @relation(fields: [projectId], references: [id])
  department Department? @relation(fields: [departmentId], references: [id])
  owner      Employee?   @relation("CredentialOwner", fields: [ownerId], references: [id])

  @@map("credentials")
}

enum DomainStatusEnum {
  ACTIVE
  EXPIRING_SOON
  EXPIRED
  TRANSFERRED
}

model Domain {
  id           String           @id @default(uuid())
  projectId    String           @map("project_id")
  domainName   String           @unique @map("domain_name")
  provider     String?
  purchaseDate DateTime?        @map("purchase_date")
  expiryDate   DateTime?        @map("expiry_date")
  renewalCost  Decimal?         @map("renewal_cost") @db.Decimal(10, 2)
  clientCharge Decimal?         @map("client_charge") @db.Decimal(10, 2)
  autoRenew    Boolean          @default(true) @map("auto_renew")
  status       DomainStatusEnum @default(ACTIVE)
  createdAt    DateTime         @default(now()) @map("created_at")
  updatedAt    DateTime         @updatedAt @map("updated_at")

  project Project @relation(fields: [projectId], references: [id])

  @@map("domains")
}

// ─── RBAC: DEPARTMENTS, ROLES, PERMISSIONS ───────────────

model Department {
  id          String                @id @default(uuid())
  name        String
  slug        String                @unique
  description String?
  parentId    String?               @map("parent_id")
  parent      Department?           @relation("DeptHierarchy", fields: [parentId], references: [id])
  children    Department[]          @relation("DeptHierarchy")
  sortOrder   Int                   @default(0) @map("sort_order")
  createdAt   DateTime              @default(now()) @map("created_at")
  updatedAt   DateTime              @updatedAt @map("updated_at")

  members     EmployeeDepartment[]
  credentials Credential[]
  invitations Invitation[]

  @@map("departments")
}

model EmployeeDepartment {
  id           String     @id @default(uuid())
  employeeId   String     @map("employee_id")
  departmentId String     @map("department_id")
  deptRole     String     @default("MEMBER") @map("dept_role")
  isPrimary    Boolean    @default(false) @map("is_primary")
  joinedAt     DateTime   @default(now()) @map("joined_at")

  employee   Employee   @relation(fields: [employeeId], references: [id], onDelete: Cascade)
  department Department @relation(fields: [departmentId], references: [id], onDelete: Cascade)

  @@unique([employeeId, departmentId])
  @@map("employee_departments")
}

model Role {
  id          String           @id @default(uuid())
  name        String
  slug        String           @unique
  description String?
  level       Int
  isSystem    Boolean          @default(false) @map("is_system")
  createdAt   DateTime         @default(now()) @map("created_at")
  updatedAt   DateTime         @updatedAt @map("updated_at")

  permissions RolePermission[]
  employees   Employee[]
  invitations Invitation[]

  @@map("roles")
}

model Permission {
  id          String           @id @default(uuid())
  module      String
  action      String
  description String?

  roles RolePermission[]

  @@unique([module, action])
  @@map("permissions")
}

model RolePermission {
  id           String @id @default(uuid())
  roleId       String @map("role_id")
  permissionId String @map("permission_id")
  scope        String

  role       Role       @relation(fields: [roleId], references: [id], onDelete: Cascade)
  permission Permission @relation(fields: [permissionId], references: [id], onDelete: Cascade)

  @@unique([roleId, permissionId])
  @@map("role_permissions")
}

model Invitation {
  id           String      @id @default(uuid())
  email        String      @unique
  roleId       String      @map("role_id")
  departmentId String?     @map("department_id")
  invitedById  String      @map("invited_by_id")
  status       String      @default("PENDING")
  token        String      @unique @default(uuid())
  expiresAt    DateTime    @map("expires_at")
  employeeId   String?     @unique @map("employee_id")
  createdAt    DateTime    @default(now()) @map("created_at")

  role       Role        @relation(fields: [roleId], references: [id])
  department Department? @relation(fields: [departmentId], references: [id])
  invitedBy  Employee    @relation("InvitedBy", fields: [invitedById], references: [id])
  employee   Employee?   @relation("InvitationEmployee", fields: [employeeId], references: [id])

  @@map("invitations")
}

// ─── EMPLOYEES & PARTNERS ─────────────────────────────────

enum EmployeeLevelEnum {
  JUNIOR
  MIDDLE
  SENIOR
  LEAD
  HEAD
}

enum EmployeeStatusEnum {
  ACTIVE
  PROBATION
  ON_LEAVE
  TERMINATED
}

model Employee {
  id           String              @id @default(uuid())
  clerkUserId  String?             @unique @map("clerk_user_id")
  firstName    String              @map("first_name")
  lastName     String              @map("last_name")
  email        String              @unique
  phone        String?
  telegram     String?
  avatar       String?
  birthday     DateTime?
  notes        String?
  position     String?
  roleId       String              @map("role_id")
  role         Role                @relation(fields: [roleId], references: [id])
  departments  EmployeeDepartment[]
  level        EmployeeLevelEnum?
  baseSalary   Decimal?            @map("base_salary") @db.Decimal(12, 2)
  workSchedule Json?               @map("work_schedule")
  hireDate     DateTime?           @map("hire_date")
  fireDate     DateTime?           @map("fire_date")
  status       EmployeeStatusEnum  @default(PROBATION)
  createdAt    DateTime            @default(now()) @map("created_at")
  updatedAt    DateTime            @updatedAt @map("updated_at")

  projectsSelling            Project[]               @relation("ProjectSeller")
  projectsManaging           Project[]               @relation("ProjectPM")
  leadsAssigned              Lead[]                  @relation("LeadAssignee")
  dealsSelling               Deal[]                  @relation("DealSeller")
  dealsPM                    Deal[]                  @relation("DealPM")
  paymentsConfirmed          Payment[]               @relation("PaymentConfirmer")
  tasksCreated               Task[]                  @relation("TaskCreator")
  tasksAssigned              Task[]                  @relation("TaskAssignee")
  ticketsAssigned            SupportTicket[]         @relation("TicketAssignee")
  bonusEntries               BonusEntry[]
  recurringTasksCreated      RecurringTaskTemplate[] @relation("RecurringTaskCreator")
  recurringTasksAssigned     RecurringTaskTemplate[] @relation("RecurringTaskAssignee")
  invitationsSent            Invitation[]            @relation("InvitedBy")
  invitationReceived         Invitation?             @relation("InvitationEmployee")
  credentialsOwned           Credential[]            @relation("CredentialOwner")

  @@map("employees")
}

enum PartnerTypeEnum {
  REGULAR
  PREMIUM
}

enum PartnerDirectionEnum {
  INBOUND
  OUTBOUND
  BOTH
}

enum PartnerStatusEnum {
  ACTIVE
  INACTIVE
}

model Partner {
  id             String               @id @default(uuid())
  name           String
  type           PartnerTypeEnum      @default(REGULAR)
  direction      PartnerDirectionEnum @default(INBOUND)
  defaultPercent Decimal              @default(30) @map("default_percent") @db.Decimal(5, 2)
  status         PartnerStatusEnum    @default(ACTIVE)
  contactId      String?              @map("contact_id")
  createdAt      DateTime             @default(now()) @map("created_at")
  updatedAt      DateTime             @updatedAt @map("updated_at")

  orders        Order[]
  subscriptions Subscription[]
  leadsAsSource Lead[] @relation("LeadSourcePartner")
  dealsAsSource Deal[] @relation("DealSourcePartner")

  @@map("partners")
}

// ─── AUDIT ────────────────────────────────────────────────

model AuditLog {
  id         String   @id @default(uuid())
  projectId  String?  @map("project_id")
  entityType String   @map("entity_type")
  entityId   String   @map("entity_id")
  action     String
  userId     String   @map("user_id")
  changes    Json?
  ipAddress  String?  @map("ip_address")
  createdAt  DateTime @default(now()) @map("created_at")

  project Project? @relation(fields: [projectId], references: [id])

  @@index([entityType, entityId])
  @@index([userId])
  @@index([createdAt])
  @@map("audit_logs")
}

// ─── SYSTEM LISTS (reference data: product types, deal types, etc.) ───

model SystemListOption {
  id        String   @id @default(uuid())
  listKey   String   @map("list_key")
  code      String
  label     String
  sortOrder Int      @default(0) @map("sort_order")
  isActive  Boolean  @default(true) @map("is_active")
  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  @@unique([listKey, code])
  @@index([listKey])
  @@map("system_list_options")
}
