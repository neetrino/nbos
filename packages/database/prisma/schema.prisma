generator client {
  provider = "prisma-client"
  output   = "../src/generated/prisma"
}

datasource db {
  provider = "postgresql"
}

// ─── CONTACT & COMPANY ────────────────────────────────────

enum ContactRole {
  CLIENT
  PARTNER
  CONTRACTOR
  OTHER
}

model Contact {
  id             String      @id @default(uuid())
  firstName      String      @map("first_name")
  lastName       String      @map("last_name")
  phone          String?
  email          String?
  messengerLinks Json?       @map("messenger_links")
  role           ContactRole @default(CLIENT)
  notes          String?
  createdAt      DateTime    @default(now()) @map("created_at")
  updatedAt      DateTime    @updatedAt @map("updated_at")

  companies     Company[]
  projects      Project[]
  leads         Lead[]
  deals         Deal[]
  tickets       SupportTicket[]
  leadsAsSource Lead[]          @relation("LeadSourceContact")
  dealsAsSource Deal[]          @relation("DealSourceContact")
  partners      Partner[]

  @@map("contacts")
}

enum CompanyType {
  LEGAL
  INDIVIDUAL
  SOLE_PROPRIETOR
}

enum TaxStatus {
  TAX
  TAX_FREE
}

model Company {
  id           String      @id @default(uuid())
  name         String
  type         CompanyType @default(LEGAL)
  taxId        String?     @map("tax_id")
  legalAddress String?     @map("legal_address")
  bankDetails  Json?       @map("bank_details")
  taxStatus    TaxStatus   @default(TAX)
  contactId    String      @map("contact_id")
  notes        String?
  createdAt    DateTime    @default(now()) @map("created_at")
  updatedAt    DateTime    @updatedAt @map("updated_at")

  contact  Contact   @relation(fields: [contactId], references: [id])
  projects Project[]
  invoices Invoice[]
  deals    Deal[]

  @@map("companies")
}

// ─── PROJECT & PRODUCT ────────────────────────────────────

model Project {
  id          String   @id @default(uuid())
  code        String   @unique
  name        String
  contactId   String   @map("contact_id")
  companyId   String?  @map("company_id")
  description String?
  isArchived  Boolean  @default(false) @map("is_archived")
  createdAt   DateTime @default(now()) @map("created_at")
  updatedAt   DateTime @updatedAt @map("updated_at")

  contact               Contact                       @relation(fields: [contactId], references: [id])
  company               Company?                      @relation(fields: [companyId], references: [id])
  products              Product[]
  extensions            Extension[]
  orders                Order[]
  subscriptions         Subscription[]
  workSpaces            WorkSpace[]
  credentials           Credential[]
  domains               Domain[]
  tickets               SupportTicket[]
  expenses              Expense[]
  expensePlans          ExpensePlan[]
  clientServiceRecords  ClientServiceRecord[]
  bonusEntries          BonusEntry[]
  auditLogs             AuditLog[]
  kickoffChecklistItems ProjectKickoffChecklistItem[]
  technicalProfiles     ProductTechnicalProfile[]
  technicalAssets       TechnicalAsset[]
  technicalEnvironments TechnicalEnvironment[]

  @@map("projects")
}

model ProjectKickoffChecklistItem {
  id          String    @id @default(uuid())
  projectId   String    @map("project_id")
  key         String
  title       String
  isRequired  Boolean   @default(true) @map("is_required")
  isChecked   Boolean   @default(false) @map("is_checked")
  note        String?
  checkedAt   DateTime? @map("checked_at")
  checkedById String?   @map("checked_by_id")
  sortOrder   Int       @map("sort_order")
  createdAt   DateTime  @default(now()) @map("created_at")
  updatedAt   DateTime  @updatedAt @map("updated_at")

  project Project @relation(fields: [projectId], references: [id], onDelete: Cascade)

  @@unique([projectId, key])
  @@index([projectId])
  @@map("project_kickoff_checklist_items")
}

enum ProductCategoryEnum {
  CODE
  WORDPRESS
  SHOPIFY
  MARKETING
  OTHER
}

enum ProductTypeEnum {
  BUSINESS_CARD_WEBSITE
  COMPANY_WEBSITE
  MOBILE_APP
  WEB_APP
  CRM
  ECOMMERCE
  SAAS
  LANDING
  ERP
  LOGO
  BRANDING
  DESIGN
  SEO
  PPC
  SMM
  OTHER
}

enum ProductStatusEnum {
  NEW
  CREATING
  DEVELOPMENT
  QA
  TRANSFER
  ON_HOLD
  DONE
  LOST
}

enum DeliveryStageEnum {
  STARTING
  DEVELOPMENT
  QA
  TRANSFER
}

enum DeliveryWorkStatusEnum {
  ACTIVE
  ON_HOLD
}

enum DeliveryResolutionEnum {
  DONE
  CANCELLED
}

model Product {
  id                   String                  @id @default(uuid())
  projectId            String                  @map("project_id")
  name                 String
  productCategory      ProductCategoryEnum     @map("product_category")
  productType          ProductTypeEnum         @map("product_type")
  status               ProductStatusEnum       @default(NEW)
  deliveryStage        DeliveryStageEnum?      @default(STARTING) @map("delivery_stage")
  deliveryWorkStatus   DeliveryWorkStatusEnum  @default(ACTIVE) @map("delivery_work_status")
  deliveryResolution   DeliveryResolutionEnum? @map("delivery_resolution")
  onHoldReason         String?                 @map("on_hold_reason")
  onHoldUntil          DateTime?               @map("on_hold_until")
  cancellationReason   String?                 @map("cancellation_reason")
  clientAcceptedAt     DateTime?               @map("client_accepted_at")
  clientAcceptedBy     String?                 @map("client_accepted_by")
  clientAcceptanceNote String?                 @map("client_acceptance_note")
  pmId                 String?                 @map("pm_id")
  deadline             DateTime?
  description          String?
  checklistTemplateId  String?                 @map("checklist_template_id")
  createdAt            DateTime                @default(now()) @map("created_at")
  updatedAt            DateTime                @updatedAt @map("updated_at")

  project               Project                   @relation(fields: [projectId], references: [id])
  pm                    Employee?                 @relation("ProductPM", fields: [pmId], references: [id])
  order                 Order?
  extensions            Extension[]
  tasks                 Task[]
  workSpace             WorkSpace?
  tickets               SupportTicket[]
  clientServiceRecords  ClientServiceRecord[]
  dealsLinked           Deal[]                    @relation("DealExistingProduct")
  technicalProfiles     ProductTechnicalProfile[]
  technicalAssets       TechnicalAsset[]
  technicalEnvironments TechnicalEnvironment[]

  @@index([deliveryStage])
  @@index([deliveryWorkStatus])
  @@index([deliveryResolution])
  @@index([onHoldUntil])
  @@index([clientAcceptedAt])
  @@map("products")
}

enum ExtensionSizeEnum {
  MICRO
  SMALL
  MEDIUM
  LARGE
}

enum ExtensionStatusEnum {
  NEW
  DEVELOPMENT
  QA
  TRANSFER
  DONE
  LOST
}

model Extension {
  id                 String                  @id @default(uuid())
  projectId          String                  @map("project_id")
  productId          String                  @map("product_id")
  name               String
  size               ExtensionSizeEnum       @default(SMALL)
  status             ExtensionStatusEnum     @default(NEW)
  deliveryStage      DeliveryStageEnum?      @default(STARTING) @map("delivery_stage")
  deliveryWorkStatus DeliveryWorkStatusEnum  @default(ACTIVE) @map("delivery_work_status")
  deliveryResolution DeliveryResolutionEnum? @map("delivery_resolution")
  onHoldReason       String?                 @map("on_hold_reason")
  onHoldUntil        DateTime?               @map("on_hold_until")
  cancellationReason String?                 @map("cancellation_reason")
  assignedTo         String?                 @map("assigned_to")
  deadline           DateTime?
  description        String?
  createdAt          DateTime                @default(now()) @map("created_at")
  updatedAt          DateTime                @updatedAt @map("updated_at")

  project   Project    @relation(fields: [projectId], references: [id])
  product   Product    @relation(fields: [productId], references: [id])
  assignee  Employee?  @relation("ExtensionAssignee", fields: [assignedTo], references: [id])
  order     Order?
  tasks     Task[]
  workSpace WorkSpace?

  @@index([deliveryStage])
  @@index([deliveryWorkStatus])
  @@index([deliveryResolution])
  @@index([onHoldUntil])
  @@index([deadline])
  @@map("extensions")
}

// ─── CRM ──────────────────────────────────────────────────

enum LeadStatusEnum {
  NEW
  ON_HOLD
  DIDNT_GET_THROUGH
  CONTACT_ESTABLISHED
  MQL
  SPAM
  SQL
}

enum LeadSourceEnum {
  MARKETING
  SALES
  PARTNER
  CLIENT
}

enum MarketingChannelEnum {
  SMM
  WEBSITE
  LIST_AM
  GOOGLE_ADS
  META_ADS
  CONTENT
  SEO
  OFFLINE
  OTHER
}

enum MarketingAccountStatusEnum {
  ACTIVE
  PAUSED
  ARCHIVED
}

enum MarketingActivityStatusEnum {
  IDEA
  PREPARING
  READY
  LAUNCHED
  FINISHED
  ARCHIVED
}

enum MarketingActivityTypeEnum {
  AD_CAMPAIGN
  SMM_POST
  STORY_REEL
  LIST_AM_PROMOTION
  WEBSITE_LANDING
  SEO_WORK
  OFFLINE_ACTIVITY
  OTHER
}

model MarketingAccount {
  id                   String                     @id @default(uuid())
  channel              MarketingChannelEnum
  name                 String
  identifier           String?
  phone                String?
  status               MarketingAccountStatusEnum @default(ACTIVE)
  financeExpensePlanId String?                    @map("finance_expense_plan_id")
  defaultCost          Decimal?                   @map("default_cost") @db.Decimal(12, 2)
  ownerId              String?                    @map("owner_id")
  notes                String?
  createdAt            DateTime                   @default(now()) @map("created_at")
  updatedAt            DateTime                   @updatedAt @map("updated_at")

  owner      Employee?           @relation("MarketingAccountOwner", fields: [ownerId], references: [id])
  activities MarketingActivity[]
  leads      Lead[]
  deals      Deal[]

  @@map("marketing_accounts")
}

model MarketingActivity {
  id            String                      @id @default(uuid())
  title         String
  channel       MarketingChannelEnum
  type          MarketingActivityTypeEnum
  status        MarketingActivityStatusEnum @default(IDEA)
  accountId     String?                     @map("account_id")
  ownerId       String?                     @map("owner_id")
  description   String?
  budget        Decimal?                    @db.Decimal(12, 2)
  currency      String                      @default("AMD")
  startDate     DateTime?                   @map("start_date")
  endDate       DateTime?                   @map("end_date")
  expectedPayAt DateTime?                   @map("expected_pay_at")
  expenseCardId String?                     @map("expense_card_id")
  expensePlanId String?                     @map("expense_plan_id")
  notes         String?
  createdAt     DateTime                    @default(now()) @map("created_at")
  updatedAt     DateTime                    @updatedAt @map("updated_at")

  account MarketingAccount? @relation(fields: [accountId], references: [id])
  owner   Employee?         @relation("MarketingActivityOwner", fields: [ownerId], references: [id])
  leads   Lead[]
  deals   Deal[]

  @@map("marketing_activities")
}

/// CRM "Where" options when From = Marketing (labels/order/active; codes match `MarketingChannelEnum`).
model MarketingCrmWhereOption {
  channel   MarketingChannelEnum @id
  label     String
  sortOrder Int                  @default(0) @map("sort_order")
  isActive  Boolean              @default(true) @map("is_active")
  createdAt DateTime             @default(now()) @map("created_at")
  updatedAt DateTime             @updatedAt @map("updated_at")

  @@map("marketing_crm_where_options")
}

model Lead {
  id                  String         @id @default(uuid())
  code                String         @unique
  name                String?
  contactName         String         @map("contact_name")
  phone               String?
  email               String?
  source              LeadSourceEnum?
  sourceDetail        String?        @map("source_detail")
  sourcePartnerId     String?        @map("source_partner_id")
  sourceContactId     String?        @map("source_contact_id")
  marketingAccountId  String?        @map("marketing_account_id")
  marketingActivityId String?        @map("marketing_activity_id")
  status              LeadStatusEnum @default(NEW)
  assignedTo          String?        @map("assigned_to")
  contactId           String?        @map("contact_id")
  notes               String?
  createdAt           DateTime       @default(now()) @map("created_at")
  updatedAt           DateTime       @updatedAt @map("updated_at")

  contact           Contact?           @relation(fields: [contactId], references: [id])
  assignee          Employee?          @relation("LeadAssignee", fields: [assignedTo], references: [id])
  sourcePartner     Partner?           @relation("LeadSourcePartner", fields: [sourcePartnerId], references: [id])
  sourceContact     Contact?           @relation("LeadSourceContact", fields: [sourceContactId], references: [id])
  marketingAccount  MarketingAccount?  @relation(fields: [marketingAccountId], references: [id])
  marketingActivity MarketingActivity? @relation(fields: [marketingActivityId], references: [id])
  deal              Deal?

  @@map("leads")
}

enum DealStatusEnum {
  START_CONVERSATION
  DISCUSS_NEEDS
  MEETING
  CAN_WE_DO_IT
  SEND_OFFER
  GET_ANSWER
  DEPOSIT_AND_CONTRACT
  FAILED
  WON
}

enum DealTypeEnum {
  PRODUCT
  EXTENSION
  MAINTENANCE
  OUTSOURCE
}

model Deal {
  id                  String               @id @default(uuid())
  code                String               @unique
  name                String?
  leadId              String?              @unique @map("lead_id")
  contactId           String               @map("contact_id")
  projectId           String?              @map("project_id")
  companyId           String?              @map("company_id")
  type                DealTypeEnum
  status              DealStatusEnum       @default(START_CONVERSATION)
  amount              Decimal?             @db.Decimal(12, 2)
  paymentType         PaymentTypeEnum?     @map("payment_type")
  taxStatus           TaxStatus            @default(TAX) @map("tax_status")
  sellerId            String               @map("seller_id")
  sellerAssistantId   String?              @map("seller_assistant_id")
  source              LeadSourceEnum?
  sourceDetail        String?              @map("source_detail")
  sourcePartnerId     String?              @map("source_partner_id")
  sourceContactId     String?              @map("source_contact_id")
  marketingAccountId  String?              @map("marketing_account_id")
  marketingActivityId String?              @map("marketing_activity_id")
  notes               String?
  productCategory     ProductCategoryEnum? @map("product_category")
  productType         String?              @map("product_type")
  pmId                String?              @map("pm_id")
  deadline            DateTime?
  existingProductId   String?              @map("existing_product_id")
  offerSentAt         DateTime?            @map("offer_sent_at")
  offerLink           String?              @map("offer_link")
  offerFileUrl        String?              @map("offer_file_url")
  offerScreenshotUrl  String?              @map("offer_screenshot_url")
  responseDueAt       DateTime?            @map("response_due_at")
  contractSignedAt    DateTime?            @map("contract_signed_at")
  contractFileUrl     String?              @map("contract_file_url")
  maintenanceStartAt  DateTime?            @map("maintenance_start_at")
  createdAt           DateTime             @default(now()) @map("created_at")
  updatedAt           DateTime             @updatedAt @map("updated_at")

  lead              Lead?              @relation(fields: [leadId], references: [id])
  contact           Contact            @relation(fields: [contactId], references: [id])
  company           Company?           @relation(fields: [companyId], references: [id])
  seller            Employee           @relation("DealSeller", fields: [sellerId], references: [id])
  sellerAssistant   Employee?          @relation("DealSellerAssistant", fields: [sellerAssistantId], references: [id])
  pm                Employee?          @relation("DealPM", fields: [pmId], references: [id])
  existingProduct   Product?           @relation("DealExistingProduct", fields: [existingProductId], references: [id])
  sourcePartner     Partner?           @relation("DealSourcePartner", fields: [sourcePartnerId], references: [id])
  sourceContact     Contact?           @relation("DealSourceContact", fields: [sourceContactId], references: [id])
  marketingAccount  MarketingAccount?  @relation(fields: [marketingAccountId], references: [id])
  marketingActivity MarketingActivity? @relation(fields: [marketingActivityId], references: [id])
  orders            Order[]
  supportTickets    SupportTicket[]

  @@map("deals")
}

// ─── FINANCE ──────────────────────────────────────────────

enum OrderTypeEnum {
  PRODUCT
  EXTENSION
  MAINTENANCE
  OUTSOURCE
}

enum PaymentTypeEnum {
  CLASSIC
  SUBSCRIPTION
}

enum OrderStatusEnum {
  ACTIVE
  PARTIALLY_PAID
  FULLY_PAID
  CLOSED
}

model Order {
  id                   String          @id @default(uuid())
  code                 String          @unique
  projectId            String          @map("project_id")
  dealId               String?         @map("deal_id")
  productId            String?         @unique @map("product_id")
  extensionId          String?         @unique @map("extension_id")
  type                 OrderTypeEnum
  paymentType          PaymentTypeEnum @map("payment_type")
  totalAmount          Decimal         @map("total_amount") @db.Decimal(12, 2)
  currency             String          @default("AMD")
  taxStatus            TaxStatus       @default(TAX) @map("tax_status")
  status               OrderStatusEnum @default(ACTIVE)
  partnerId            String?         @map("partner_id")
  partnerPercent       Decimal?        @default(30) @map("partner_percent") @db.Decimal(5, 2)
  sellerBonusPercent   Decimal?        @map("seller_bonus_percent") @db.Decimal(5, 2)
  deliveryBonusPercent Decimal?        @map("delivery_bonus_percent") @db.Decimal(5, 2)
  sellerBonusSource    LeadSourceEnum? @map("seller_bonus_source")
  createdAt            DateTime        @default(now()) @map("created_at")
  updatedAt            DateTime        @updatedAt @map("updated_at")

  project      Project      @relation(fields: [projectId], references: [id])
  deal         Deal?        @relation(fields: [dealId], references: [id])
  product      Product?     @relation(fields: [productId], references: [id])
  extension    Extension?   @relation(fields: [extensionId], references: [id])
  partner      Partner?     @relation(fields: [partnerId], references: [id])
  invoices     Invoice[]
  bonusEntries BonusEntry[]

  @@map("orders")
}

enum InvoiceTypeEnum {
  DEVELOPMENT
  EXTENSION
  SUBSCRIPTION
  DOMAIN
  SERVICE
}

enum InvoiceStatusEnum {
  THIS_MONTH
  CREATE_INVOICE
  WAITING
  DELAYED
  ON_HOLD
  FAIL
  PAID
}

model Invoice {
  id                    String            @id @default(uuid())
  code                  String            @unique
  orderId               String?           @map("order_id")
  subscriptionId        String?           @map("subscription_id")
  projectId             String            @map("project_id")
  companyId             String?           @map("company_id")
  clientServiceRecordId String?           @map("client_service_record_id")
  amount                Decimal           @db.Decimal(12, 2)
  taxStatus             TaxStatus         @default(TAX) @map("tax_status")
  type                  InvoiceTypeEnum
  status                InvoiceStatusEnum @default(THIS_MONTH)
  dueDate               DateTime?         @map("due_date")
  paidDate              DateTime?         @map("paid_date")
  govInvoiceId          String?           @map("gov_invoice_id")
  paymentLink           String?           @map("payment_link")
  createdAt             DateTime          @default(now()) @map("created_at")
  updatedAt             DateTime          @updatedAt @map("updated_at")

  order               Order?               @relation(fields: [orderId], references: [id])
  subscription        Subscription?        @relation(fields: [subscriptionId], references: [id])
  company             Company?             @relation(fields: [companyId], references: [id])
  clientServiceRecord ClientServiceRecord? @relation(fields: [clientServiceRecordId], references: [id], onDelete: SetNull)
  payments            Payment[]

  @@index([clientServiceRecordId])
  @@map("invoices")
}

model Payment {
  id            String   @id @default(uuid())
  invoiceId     String   @map("invoice_id")
  amount        Decimal  @db.Decimal(12, 2)
  paymentDate   DateTime @map("payment_date")
  paymentMethod String?  @map("payment_method")
  confirmedBy   String?  @map("confirmed_by")
  notes         String?
  createdAt     DateTime @default(now()) @map("created_at")
  updatedAt     DateTime @updatedAt @map("updated_at")

  invoice   Invoice   @relation(fields: [invoiceId], references: [id])
  confirmer Employee? @relation("PaymentConfirmer", fields: [confirmedBy], references: [id])

  @@map("payments")
}

enum SubscriptionTypeEnum {
  MAINTENANCE_ONLY
  DEV_AND_MAINTENANCE
  DEV_ONLY
  PARTNER_SERVICE
}

enum SubscriptionStatusEnum {
  PENDING
  ACTIVE
  ON_HOLD
  CANCELLED
  COMPLETED
}

model Subscription {
  id         String                 @id @default(uuid())
  code       String                 @unique
  projectId  String                 @map("project_id")
  type       SubscriptionTypeEnum
  amount     Decimal                @db.Decimal(12, 2)
  billingDay Int                    @map("billing_day")
  taxStatus  TaxStatus              @default(TAX) @map("tax_status")
  startDate  DateTime               @map("start_date")
  endDate    DateTime?              @map("end_date")
  status     SubscriptionStatusEnum @default(ACTIVE)
  partnerId  String?                @map("partner_id")
  createdAt  DateTime               @default(now()) @map("created_at")
  updatedAt  DateTime               @updatedAt @map("updated_at")

  project  Project   @relation(fields: [projectId], references: [id])
  partner  Partner?  @relation(fields: [partnerId], references: [id])
  invoices Invoice[]

  @@map("subscriptions")
}

enum ExpenseTypeEnum {
  PLANNED
  UNPLANNED
}

enum ExpenseCategoryEnum {
  DOMAIN
  HOSTING
  SERVICE
  MARKETING
  SALARY
  BONUS
  PARTNER_PAYOUT
  TOOLS
  OTHER
}

enum ExpenseFrequency {
  ONE_TIME
  MONTHLY
  QUARTERLY
  YEARLY
  MULTI_YEAR
}

enum ExpenseStatusEnum {
  THIS_MONTH
  PAY_NOW
  DELAYED
  ON_HOLD
  PAID
  UNPAID
}

enum ExpenseBacklogReasonEnum {
  DEBT_PAY_LATER
  WAITING_DECISION
  WAITING_CLIENT
  WAITING_PROVIDER
  OTHER
}

model ExpensePlan {
  id                    String              @id @default(uuid())
  name                  String
  category              ExpenseCategoryEnum
  amount                Decimal             @db.Decimal(12, 2)
  frequency             ExpenseFrequency    @default(ONE_TIME)
  nextDueDate           DateTime?           @map("next_due_date")
  provider              String?
  projectId             String?             @map("project_id")
  clientServiceRecordId String?             @map("client_service_record_id")
  autoGenerate          Boolean             @default(false) @map("auto_generate")
  notes                 String?
  createdAt             DateTime            @default(now()) @map("created_at")
  updatedAt             DateTime            @updatedAt @map("updated_at")

  project             Project?             @relation(fields: [projectId], references: [id], onDelete: SetNull)
  clientServiceRecord ClientServiceRecord? @relation(fields: [clientServiceRecordId], references: [id], onDelete: SetNull)
  expenses            Expense[]

  @@index([projectId])
  @@index([clientServiceRecordId])
  @@map("expense_plans")
}

model Expense {
  id                    String                    @id @default(uuid())
  type                  ExpenseTypeEnum
  category              ExpenseCategoryEnum
  name                  String
  amount                Decimal                   @db.Decimal(12, 2)
  frequency             ExpenseFrequency          @default(ONE_TIME)
  dueDate               DateTime?                 @map("due_date")
  status                ExpenseStatusEnum         @default(THIS_MONTH)
  projectId             String?                   @map("project_id")
  expensePlanId         String?                   @map("expense_plan_id")
  clientServiceRecordId String?                   @map("client_service_record_id")
  isPassThrough         Boolean                   @default(false) @map("is_pass_through")
  taxStatus             TaxStatus                 @default(TAX) @map("tax_status")
  backlogReason         ExpenseBacklogReasonEnum? @map("backlog_reason")
  notes                 String?
  createdAt             DateTime                  @default(now()) @map("created_at")
  updatedAt             DateTime                  @updatedAt @map("updated_at")

  project             Project?             @relation(fields: [projectId], references: [id])
  expensePlan         ExpensePlan?         @relation(fields: [expensePlanId], references: [id], onDelete: SetNull)
  clientServiceRecord ClientServiceRecord? @relation(fields: [clientServiceRecordId], references: [id], onDelete: SetNull)
  expensePayments     ExpensePayment[]
  salaryLine          SalaryLine?

  @@index([expensePlanId])
  @@index([clientServiceRecordId])
  @@map("expenses")
}

model ExpensePayment {
  id          String   @id @default(uuid())
  expenseId   String   @map("expense_id")
  amount      Decimal  @db.Decimal(12, 2)
  paymentDate DateTime @map("payment_date")
  notes       String?
  createdAt   DateTime @default(now()) @map("created_at")
  updatedAt   DateTime @updatedAt @map("updated_at")

  expense Expense @relation(fields: [expenseId], references: [id], onDelete: Cascade)

  @@map("expense_payments")
}

enum BonusTypeEnum {
  SALES
  DELIVERY
  PM
  DESIGN
  MARKETING
}

enum BonusStatusEnum {
  INCOMING
  EARNED
  PENDING_ELIGIBILITY
  VESTED
  HOLDBACK
  ACTIVE
  PAID
  CLAWBACK
}

model BonusEntry {
  id                  String          @id @default(uuid())
  employeeId          String          @map("employee_id")
  orderId             String          @map("order_id")
  projectId           String          @map("project_id")
  type                BonusTypeEnum
  amount              Decimal         @db.Decimal(12, 2)
  percent             Decimal         @db.Decimal(5, 2)
  status              BonusStatusEnum @default(INCOMING)
