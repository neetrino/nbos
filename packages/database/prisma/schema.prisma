enum TaskStatusEnum {
  NEW
  IN_PROGRESS
  DONE
  DEFERRED
  CANCELLED
}

enum TaskPriorityEnum {
  CRITICAL
  HIGH
  NORMAL
  LOW
}

enum WorkSpaceTypeEnum {
  PRODUCT_DELIVERY
  EXTENSION_DELIVERY
  STANDALONE_OPERATIONAL
}

enum TaskPlanningStatusEnum {
  UNPLANNED
  BACKLOG
  FUTURE_SPRINT
  ACTIVE_SPRINT
}

model WorkSpace {
  id           String            @id @default(uuid())
  projectId    String?           @map("project_id")
  productId    String?           @unique @map("product_id")
  extensionId  String?           @unique @map("extension_id")
  name         String
  type         WorkSpaceTypeEnum
  scrumEnabled Boolean           @default(false) @map("scrum_enabled")
  description  String?
  createdAt    DateTime          @default(now()) @map("created_at")
  updatedAt    DateTime          @updatedAt @map("updated_at")

  project   Project?   @relation(fields: [projectId], references: [id])
  product   Product?   @relation(fields: [productId], references: [id])
  extension Extension? @relation(fields: [extensionId], references: [id])
