// ─── PROJECT & PRODUCT ────────────────────────────────────

model Project {
  id          String   @id @default(uuid())
  code        String   @unique
  name        String
  contactId   String   @map("contact_id")
  companyId   String?  @map("company_id")
  description String?
  isArchived  Boolean  @default(false) @map("is_archived")
  createdAt   DateTime @default(now()) @map("created_at")
  updatedAt   DateTime @updatedAt @map("updated_at")

  contact                   Contact                       @relation(fields: [contactId], references: [id])
  company                   Company?                      @relation(fields: [companyId], references: [id])
  products                  Product[]
  extensions                Extension[]
  orders                    Order[]
  subscriptions             Subscription[]
  workSpaces                WorkSpace[]
  credentials               Credential[]
  credentialFolders         CredentialFolder[]
  domains                   Domain[]
  tickets                   SupportTicket[]
  expenses                  Expense[]
  expensePlans              ExpensePlan[]
  clientServiceRecords      ClientServiceRecord[]
  bonusEntries              BonusEntry[]
  bonusReleases             BonusRelease[]
  productBonusPools         ProductBonusPool[]
  payrollBonusAllocationDrafts PayrollBonusAllocationDraft[]
  auditLogs                 AuditLog[]
  kickoffChecklistItems     ProjectKickoffChecklistItem[]
  technicalProfiles         ProductTechnicalProfile[]
  technicalAssets           TechnicalAsset[]
  technicalEnvironments     TechnicalEnvironment[]
  operationalJournalEntries OperationalJournalEntry[]
  partnerAccruals           PartnerAccrual[]
  partnerServiceTerms       PartnerServiceTerm[]
  additionalContacts        ProjectAdditionalContact[]
  invoices                  Invoice[]
  teamMembers               ProjectTeamMember[]

  @@map("projects")
}

/// Extra client contacts on a project (v1 list; main person stays `Project.contactId`).
model ProjectAdditionalContact {
  projectId String @map("project_id")
  contactId String @map("contact_id")

  project Project @relation(fields: [projectId], references: [id], onDelete: Cascade)
  contact Contact @relation("ProjectAdditionalContact", fields: [contactId], references: [id], onDelete: Cascade)

  @@id([projectId, contactId])
  @@map("project_additional_contacts")
}

model ProjectKickoffChecklistItem {
  id          String    @id @default(uuid())
  projectId   String    @map("project_id")
  key         String
  title       String
  isRequired  Boolean   @default(true) @map("is_required")
  isChecked   Boolean   @default(false) @map("is_checked")
  note        String?
  checkedAt   DateTime? @map("checked_at")
  checkedById String?   @map("checked_by_id")
  sortOrder   Int       @map("sort_order")
  createdAt   DateTime  @default(now()) @map("created_at")
  updatedAt   DateTime  @updatedAt @map("updated_at")

  project Project @relation(fields: [projectId], references: [id], onDelete: Cascade)

  @@unique([projectId, key])
  @@index([projectId])
  @@map("project_kickoff_checklist_items")
}

enum ProductCategoryEnum {
  CODE
  WORDPRESS
  SHOPIFY
  MARKETING
  OTHER
}

enum ProductTypeEnum {
  BUSINESS_CARD_WEBSITE
  COMPANY_WEBSITE
  MOBILE_APP
  WEB_APP
  CRM
  ECOMMERCE
  SAAS
  LANDING
  ERP
  LOGO
  BRANDING
  DESIGN
  SEO
  PPC
  SMM
  OTHER
}

enum ProductStatusEnum {
  NEW
  CREATING
  DEVELOPMENT
  QA
  TRANSFER
  ON_HOLD
  DONE
  LOST
}

enum DeliveryStageEnum {
  STARTING
  DEVELOPMENT
  QA
  TRANSFER
}

enum DeliveryWorkStatusEnum {
  ACTIVE
  ON_HOLD
}

enum DeliveryResolutionEnum {
  DONE
  CANCELLED
}

model Product {
  id                   String                  @id @default(uuid())
  projectId            String                  @map("project_id")
  name                 String
  productCategory      ProductCategoryEnum     @map("product_category")
  productType          ProductTypeEnum         @map("product_type")
  status               ProductStatusEnum       @default(NEW)
  deliveryStage        DeliveryStageEnum?      @default(STARTING) @map("delivery_stage")
  deliveryWorkStatus   DeliveryWorkStatusEnum  @default(ACTIVE) @map("delivery_work_status")
  deliveryResolution   DeliveryResolutionEnum? @map("delivery_resolution")
  onHoldReason         String?                 @map("on_hold_reason")
  onHoldUntil          DateTime?               @map("on_hold_until")
  cancellationReason   String?                 @map("cancellation_reason")
  clientAcceptedAt     DateTime?               @map("client_accepted_at")
  clientAcceptedBy     String?                 @map("client_accepted_by")
  clientAcceptanceNote String?                 @map("client_acceptance_note")
  pmId                    String?                 @map("pm_id")
  developerId             String?                 @map("developer_id")
  designerId              String?                 @map("designer_id")
  technicalSpecialistId   String?                 @map("technical_specialist_id")
  qaLeadId                String?                 @map("qa_lead_id")
  deadline             DateTime?
  description          String?
  checklistTemplateId  String?                 @map("checklist_template_id")
  /// ISO-like language codes for delivery UI (e.g. hy, en, ru); display order enforced in app.
  languages            String[]                @default([]) @map("languages")
  closedAt             DateTime?               @map("closed_at")
  closedById           String?                 @map("closed_by_id")
  createdAt            DateTime                @default(now()) @map("created_at")
  updatedAt            DateTime                @updatedAt @map("updated_at")

  project                   Project                    @relation(fields: [projectId], references: [id])
  pm                        Employee?                  @relation("ProductPM", fields: [pmId], references: [id])
  developer                 Employee?                  @relation("ProductDeveloper", fields: [developerId], references: [id])
  designer                  Employee?                  @relation("ProductDesigner", fields: [designerId], references: [id])
  technicalSpecialist       Employee?                  @relation("ProductTechnicalSpecialist", fields: [technicalSpecialistId], references: [id])
  qaLead                    Employee?                  @relation("ProductQaLead", fields: [qaLeadId], references: [id])
  closedBy                  Employee?                  @relation("ProductClosedBy", fields: [closedById], references: [id])
  order                     Order?
  extensions                Extension[]
  tasks                     Task[]
  workSpace                 WorkSpace?
  tickets                   SupportTicket[]
  clientServiceRecords      ClientServiceRecord[]
  dealsLinked               Deal[]                     @relation("DealExistingProduct")
  productBonusPools         ProductBonusPool[]
  bonusReleases             BonusRelease[]
  technicalProfiles         ProductTechnicalProfile[]
  technicalAssets           TechnicalAsset[]
  technicalEnvironments     TechnicalEnvironment[]
  operationalJournalEntries OperationalJournalEntry[]
  partnerAccruals           PartnerAccrual[]
  checklistTemplate         ChecklistTemplate?         @relation(fields: [checklistTemplateId], references: [id], onDelete: SetNull)
  accessSlotBindings        ProductAccessSlotBinding[]
  teamMembers               ProductTeamMember[]

  @@index([deliveryStage])
  @@index([deliveryWorkStatus])
  @@index([deliveryResolution])
  @@index([onHoldUntil])
  @@index([clientAcceptedAt])
  @@index([closedAt])
  @@index([developerId])
  @@index([designerId])
  @@index([technicalSpecialistId])
  @@index([qaLeadId])
  @@map("products")
}

/**
 * Binds a delivery access slot on a product to a Credential vault record.
 */
model ProductAccessSlotBinding {
  id           String   @id @default(uuid())
  productId    String   @map("product_id")
  slotKey      String   @map("slot_key")
  credentialId String   @map("credential_id")
  createdAt    DateTime @default(now()) @map("created_at")
  updatedAt    DateTime @updatedAt @map("updated_at")

  product    Product    @relation(fields: [productId], references: [id], onDelete: Cascade)
  credential Credential @relation(fields: [credentialId], references: [id], onDelete: Cascade)

  @@unique([productId, credentialId])
  @@index([productId, slotKey])
  @@index([credentialId])
  @@map("product_access_slot_bindings")
}

enum ExtensionSizeEnum {
  MICRO
  SMALL
  MEDIUM
  LARGE
}

enum ExtensionStatusEnum {
  NEW
  DEVELOPMENT
  QA
  TRANSFER
  DONE
  LOST
}

model Extension {
  id                 String                  @id @default(uuid())
  projectId          String                  @map("project_id")
  productId          String                  @map("product_id")
  name               String
  size               ExtensionSizeEnum       @default(SMALL)
  status             ExtensionStatusEnum     @default(NEW)
  deliveryStage      DeliveryStageEnum?      @default(STARTING) @map("delivery_stage")
  deliveryWorkStatus DeliveryWorkStatusEnum  @default(ACTIVE) @map("delivery_work_status")
  deliveryResolution DeliveryResolutionEnum? @map("delivery_resolution")
  onHoldReason       String?                 @map("on_hold_reason")
  onHoldUntil        DateTime?               @map("on_hold_until")
  cancellationReason String?                 @map("cancellation_reason")
  assignedTo         String?                 @map("assigned_to")
  deadline           DateTime?
  description        String?
  closedAt           DateTime?               @map("closed_at")
  closedById         String?                 @map("closed_by_id")
  createdAt          DateTime                @default(now()) @map("created_at")
  updatedAt          DateTime                @updatedAt @map("updated_at")

  project           Project            @relation(fields: [projectId], references: [id])
  product           Product            @relation(fields: [productId], references: [id])
  assignee          Employee?          @relation("ExtensionAssignee", fields: [assignedTo], references: [id])
  closedBy          Employee?          @relation("ExtensionClosedBy", fields: [closedById], references: [id])
  order             Order?
  productBonusPools ProductBonusPool[]
  bonusReleases     BonusRelease[]
  tasks             Task[]
  workSpace         WorkSpace?

  @@index([deliveryStage])
  @@index([deliveryWorkStatus])
  @@index([deliveryResolution])
  @@index([onHoldUntil])
  @@index([deadline])
  @@index([closedAt])
  @@map("extensions")
}
