// ─── RBAC: DEPARTMENTS, ROLES, PERMISSIONS ───────────────

model Department {
  id          String       @id @default(uuid())
  name        String
  slug        String       @unique
  description String?
  parentId    String?      @map("parent_id")
  parent      Department?  @relation("DeptHierarchy", fields: [parentId], references: [id])
  children    Department[] @relation("DeptHierarchy")
  sortOrder   Int          @default(0) @map("sort_order")
  createdAt   DateTime     @default(now()) @map("created_at")
  updatedAt   DateTime     @updatedAt @map("updated_at")

  members                   EmployeeDepartment[]
  credentials               Credential[]
  invitations               Invitation[]
  operationalJournalEntries OperationalJournalEntry[]

  @@map("departments")
}

model EmployeeDepartment {
  id           String   @id @default(uuid())
  employeeId   String   @map("employee_id")
  departmentId String   @map("department_id")
  deptRole     String   @default("MEMBER") @map("dept_role")
  isPrimary    Boolean  @default(false) @map("is_primary")
  joinedAt     DateTime @default(now()) @map("joined_at")

  employee   Employee   @relation(fields: [employeeId], references: [id], onDelete: Cascade)
  department Department @relation(fields: [departmentId], references: [id], onDelete: Cascade)

  @@unique([employeeId, departmentId])
  @@map("employee_departments")
}

model Role {
  id          String   @id @default(uuid())
  name        String
  slug        String   @unique
  description String?
  level       Int
  isSystem    Boolean  @default(false) @map("is_system")
  createdAt   DateTime @default(now()) @map("created_at")
  updatedAt   DateTime @updatedAt @map("updated_at")

  permissions        RolePermission[]
  employees          Employee[]
  invitations        Invitation[]
  roleAccessPolicies RoleAccessPolicy[]

  @@map("roles")
}

model Permission {
  id          String  @id @default(uuid())
  module      String
  action      String
  description String?

  roles RolePermission[]

  @@unique([module, action])
  @@map("permissions")
}

model RolePermission {
  id           String @id @default(uuid())
  roleId       String @map("role_id")
  permissionId String @map("permission_id")
  scope        String

  role       Role       @relation(fields: [roleId], references: [id], onDelete: Cascade)
  permission Permission @relation(fields: [permissionId], references: [id], onDelete: Cascade)

  @@unique([roleId, permissionId])
  @@map("role_permissions")
}

model Invitation {
  id           String   @id @default(uuid())
  email        String   @unique
  roleId       String   @map("role_id")
  departmentId String?  @map("department_id")
  invitedById  String   @map("invited_by_id")
  status       String   @default("PENDING")
  token        String   @unique @default(uuid())
  expiresAt    DateTime @map("expires_at")
  employeeId   String?  @unique @map("employee_id")
  createdAt    DateTime @default(now()) @map("created_at")

  role       Role        @relation(fields: [roleId], references: [id])
  department Department? @relation(fields: [departmentId], references: [id])
  invitedBy  Employee    @relation("InvitedBy", fields: [invitedById], references: [id])
  employee   Employee?   @relation("InvitationEmployee", fields: [employeeId], references: [id])

  @@map("invitations")
}
