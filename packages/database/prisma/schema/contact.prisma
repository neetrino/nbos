// ─── CONTACT & COMPANY ────────────────────────────────────

enum ContactRole {
  CLIENT
  PARTNER
  CONTRACTOR
  OTHER
}

model Contact {
  id             String      @id @default(uuid())
  firstName      String      @map("first_name")
  lastName       String      @map("last_name")
  phone          String?
  email          String?
  messengerLinks Json?       @map("messenger_links")
  role           ContactRole @default(CLIENT)
  notes          String?
  createdAt      DateTime    @default(now()) @map("created_at")
  updatedAt      DateTime    @updatedAt @map("updated_at")

  companies           Company[] @relation("CompanyPrimaryContact")
  billingForCompanies Company[] @relation("CompanyBillingContact")
  projects            Project[]
  leads               Lead[]
  deals               Deal[]
  tickets             SupportTicket[]
  leadsAsSource       Lead[]               @relation("LeadSourceContact")
  dealsAsSource       Deal[]               @relation("DealSourceContact")
  dealAdditionalLinks DealAdditionalContact[] @relation("DealAdditionalContact")
  leadAdditionalLinks LeadAdditionalContact[] @relation("LeadAdditionalContact")
  partners            Partner[]
  partnerServiceTerms PartnerServiceTerm[]

  @@map("contacts")
}

enum CompanyType {
  LEGAL
  INDIVIDUAL
  SOLE_PROPRIETOR
}

enum TaxStatus {
  TAX
  TAX_FREE
}

model Company {
  id           String      @id @default(uuid())
  name         String
  type         CompanyType @default(LEGAL)
  taxId        String?     @map("tax_id")
  legalAddress String?     @map("legal_address")
  bankDetails  Json?       @map("bank_details")
  taxStatus    TaxStatus   @default(TAX)
  contactId    String      @map("contact_id")
  billingContactId String? @map("billing_contact_id")
  phone        String?
  email        String?
  country      String?
  notes        String?
  createdAt    DateTime    @default(now()) @map("created_at")
  updatedAt    DateTime    @updatedAt @map("updated_at")

  contact                   Contact                   @relation("CompanyPrimaryContact", fields: [contactId], references: [id])
  billingContact            Contact?                  @relation("CompanyBillingContact", fields: [billingContactId], references: [id])
  projects                  Project[]
  invoices                  Invoice[]
  deals                     Deal[]
  operationalJournalEntries OperationalJournalEntry[]
  partnerServiceTerms       PartnerServiceTerm[]

  @@map("companies")
}
