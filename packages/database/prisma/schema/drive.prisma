// ─── DRIVE FILE ASSETS ─────────────────────────────────────

enum FileAssetTypeEnum {
  DOCUMENT
  IMAGE
  VIDEO
  AUDIO
  ARCHIVE
  CODE
  SPREADSHEET
  LINK
  OTHER
}

enum FilePurposeEnum {
  OFFER_DRAFT
  OFFER_SENT
  OFFER_APPROVED
  MESSENGER_PROOF
  CONTRACT
  HANDOFF_DOCUMENT
  DESIGN_ASSET
  DELIVERY_FILE
  INVOICE_REQUEST_PROOF
  PAYMENT_PROOF
  EXPENSE_PROOF
  PARTNER_AGREEMENT
  SUPPORT_EVIDENCE
  TASK_ATTACHMENT
  WORKSPACE_ARTIFACT
  SOP_DOCUMENT
  TRAINING_MATERIAL
  MEETING_RECORDING
  CALL_RECORDING
  OTHER
}

enum FileAssetStatusEnum {
  DRAFT
  ACTIVE
  APPROVED
  ARCHIVED
  DELETED
}

enum FileVisibilityEnum {
  INTERNAL
  PROJECT_TEAM
  RESTRICTED
  CLIENT_VISIBLE
  PARTNER_VISIBLE
  PERSONAL
}

enum FileConfidentialityEnum {
  PUBLIC_INTERNAL
  CONFIDENTIAL
  FINANCE_SENSITIVE
  LEGAL_SENSITIVE
  SECRET_ADJACENT
}

enum FileStorageProviderEnum {
  R2
  EXTERNAL_URL
  GOOGLE_DRIVE
}

enum FileLinkTypeEnum {
  ATTACHMENT
  APPROVED_DOCUMENT
  PROOF
  SOURCE_MATERIAL
  FINAL_DELIVERY
  HANDOFF
  SUPPORT_EVIDENCE
  TASK_ATTACHMENT
  WORKSPACE_ARTIFACT
  OTHER
}

enum DriveSpaceEnum {
  COMPANY
  PERSONAL
}

enum DriveFolderItemTypeEnum {
  FILE
  FOLDER
}

enum DriveZipExportJobStatusEnum {
  QUEUED
  PROCESSING
  COMPLETED
  FAILED
  CANCELLED
}

model FileAsset {
  id               String                  @id @default(uuid())
  displayName      String                  @map("display_name")
  originalName     String?                 @map("original_name")
  fileType         FileAssetTypeEnum       @map("file_type")
  purpose          FilePurposeEnum?
  sourceModule     String?                 @map("source_module")
  ownerId          String?                 @map("owner_id")
  createdById      String?                 @map("created_by_id")
  status           FileAssetStatusEnum     @default(ACTIVE)
  visibility       FileVisibilityEnum      @default(INTERNAL)
  confidentiality  FileConfidentialityEnum @default(CONFIDENTIAL)
  storageProvider  FileStorageProviderEnum @default(R2) @map("storage_provider")
  storageKey       String?                 @map("storage_key")
  externalUrl      String?                 @map("external_url")
  mimeType         String?                 @map("mime_type")
  sizeBytes        BigInt?                 @map("size_bytes")
  checksum         String?
  currentVersionId String?                 @map("current_version_id")
  retentionPolicy  String?                 @map("retention_policy")
  deletedAt        DateTime?               @map("deleted_at")
  archivedAt       DateTime?               @map("archived_at")
  createdAt        DateTime                @default(now()) @map("created_at")
  updatedAt        DateTime                @updatedAt @map("updated_at")

  versions                    FileVersion[]
  links                       FileLink[]
  folderPlacements            DriveFolderItem[]                  @relation("DriveFolderItemFileAsset")
  auditEvents                 FileAuditEvent[]
  documentCovers              Document[]                          @relation("DocumentCoverAsset")
  documentAttachments         DocumentAttachment[]
  messengerChannelAttachments MessengerChannelMessageAttachment[]
  messengerDirectAttachments  MessengerDirectMessageAttachment[]
  emailAttachments            EmailAttachment[]
  reportExportJobs            ReportExportJob[]
  driveZipExportOutputs       DriveZipExportJob[]                @relation("DriveZipExportOutputFile")
  partnerAgreementDocuments   Partner[]                  @relation("PartnerAgreementDocument")
  assetGrants                 FileAssetGrant[]

  @@index([status])
  @@index([purpose])
  @@index([sourceModule])
  @@index([storageKey])
  @@index([createdAt])
  @@map("file_assets")
}

model FileAssetGrant {
  id                String    @id @default(uuid())
  fileAssetId       String    @map("file_asset_id")
  granteeEmployeeId String    @map("grantee_employee_id")
  grantedById       String?   @map("granted_by_id")
  permission        String    @default("VIEW")
  expiresAt         DateTime? @map("expires_at")
  revokedAt         DateTime? @map("revoked_at")
  createdAt         DateTime  @default(now()) @map("created_at")

  fileAsset FileAsset @relation(fields: [fileAssetId], references: [id], onDelete: Cascade)

  @@index([fileAssetId])
  @@index([granteeEmployeeId, revokedAt])
  @@map("file_asset_grants")
}

model DriveZipExportJob {
  id              String                     @id @default(uuid())
  status          DriveZipExportJobStatusEnum @default(QUEUED)
  requestedById String                     @map("requested_by_id")
  fileIds         Json                       @map("file_ids")
  accessSnapshot  Json                       @map("access_snapshot")
  fileAssetId     String?                    @map("file_asset_id")
  errorMessage    String?                    @map("error_message")
  queuedAt        DateTime                   @default(now()) @map("queued_at")
  startedAt       DateTime?                  @map("started_at")
  completedAt     DateTime?                  @map("completed_at")
  failedAt        DateTime?                  @map("failed_at")
  createdAt       DateTime                   @default(now()) @map("created_at")
  updatedAt       DateTime                   @updatedAt @map("updated_at")

  requestedBy Employee   @relation(fields: [requestedById], references: [id], onDelete: Restrict)
  fileAsset     FileAsset? @relation("DriveZipExportOutputFile", fields: [fileAssetId], references: [id], onDelete: SetNull)

  @@index([requestedById, queuedAt])
  @@index([status, queuedAt])
  @@index([fileAssetId])
  @@map("drive_zip_export_jobs")
}

model DriveFolder {
  id          String         @id @default(uuid())
  name        String
  space       DriveSpaceEnum
  ownerId     String?        @map("owner_id")
  createdById String?        @map("created_by_id")
  parentId    String?        @map("parent_id")
  archivedAt  DateTime?      @map("archived_at")
  deletedAt   DateTime?      @map("deleted_at")
  createdAt   DateTime       @default(now()) @map("created_at")
  updatedAt   DateTime       @updatedAt @map("updated_at")

  parent              DriveFolder?      @relation("DriveFolderTree", fields: [parentId], references: [id], onDelete: SetNull)
  children            DriveFolder[]     @relation("DriveFolderTree")
  folderItems         DriveFolderItem[] @relation("DriveFolderItemFolder")
  childFolderPlacements DriveFolderItem[] @relation("DriveFolderItemChildFolder")

  @@index([space, ownerId])
  @@index([parentId])
  @@index([deletedAt])
  @@map("drive_folders")
}

model DriveFolderItem {
  id            String                  @id @default(uuid())
  folderId      String                  @map("folder_id")
  itemType      DriveFolderItemTypeEnum @map("item_type")
  fileAssetId   String?                 @map("file_asset_id")
  childFolderId String?                 @map("child_folder_id")
  placedById    String?                 @map("placed_by_id")
  placedAt      DateTime                @default(now()) @map("placed_at")
  removedAt     DateTime?               @map("removed_at")

  folder      DriveFolder  @relation("DriveFolderItemFolder", fields: [folderId], references: [id], onDelete: Cascade)
  fileAsset   FileAsset?   @relation("DriveFolderItemFileAsset", fields: [fileAssetId], references: [id], onDelete: Cascade)
  childFolder DriveFolder? @relation("DriveFolderItemChildFolder", fields: [childFolderId], references: [id], onDelete: Cascade)

  @@index([folderId, removedAt])
  @@index([fileAssetId])
  @@index([childFolderId])
  @@map("drive_folder_items")
}

model FileVersion {
  id            String   @id @default(uuid())
  fileAssetId   String   @map("file_asset_id")
  versionNumber Int      @map("version_number")
  storageKey    String?  @map("storage_key")
  uploadedById  String?  @map("uploaded_by_id")
  uploadedAt    DateTime @default(now()) @map("uploaded_at")
  changeNote    String?  @map("change_note")
  sizeBytes     BigInt?  @map("size_bytes")
  checksum      String?
  isCurrent     Boolean  @default(true) @map("is_current")

  fileAsset FileAsset @relation(fields: [fileAssetId], references: [id], onDelete: Cascade)

  @@unique([fileAssetId, versionNumber])
  @@index([isCurrent])
  @@map("file_versions")
}

model FileLink {
  id              String           @id @default(uuid())
  fileAssetId     String           @map("file_asset_id")
  entityType      String           @map("entity_type")
  entityId        String           @map("entity_id")
  linkType        FileLinkTypeEnum @default(ATTACHMENT) @map("link_type")
  purposeOverride FilePurposeEnum? @map("purpose_override")
  isPrimary       Boolean          @default(false) @map("is_primary")
  linkedById      String?          @map("linked_by_id")
  linkedAt        DateTime         @default(now()) @map("linked_at")
  unlinkedAt      DateTime?        @map("unlinked_at")

  fileAsset FileAsset @relation(fields: [fileAssetId], references: [id], onDelete: Cascade)

  @@index([entityType, entityId])
  @@index([fileAssetId])
  @@index([unlinkedAt])
  @@map("file_links")
}

model FileAuditEvent {
  id          String   @id @default(uuid())
  fileAssetId String   @map("file_asset_id")
  actorId     String?  @map("actor_id")
  action      String
  metadata    Json?
  createdAt   DateTime @default(now()) @map("created_at")

  fileAsset FileAsset @relation(fields: [fileAssetId], references: [id], onDelete: Cascade)

  @@index([fileAssetId])
  @@index([actorId])
  @@index([createdAt])
  @@map("file_audit_events")
}

enum FileUploadSessionStatusEnum {
  PENDING
  COMPLETED
  FAILED
  EXPIRED
}

model FileUploadSession {
  id              String                      @id @default(uuid())
  status          FileUploadSessionStatusEnum @default(PENDING)
  storageKey      String                      @map("storage_key")
  entityType      String                      @map("entity_type")
  entityId        String                      @map("entity_id")
  displayName     String                      @map("display_name")
  originalName    String?                     @map("original_name")
  mimeType        String?                     @map("mime_type")
  purpose         FilePurposeEnum?
  sourceModule    String?                     @map("source_module")
  visibility      FileVisibilityEnum          @default(INTERNAL)
  confidentiality FileConfidentialityEnum     @default(CONFIDENTIAL)
  linkType        FileLinkTypeEnum            @default(ATTACHMENT) @map("link_type")
  createdById     String?                     @map("created_by_id")
  fileAssetId     String?                     @map("file_asset_id")
  folderId        String?                     @map("folder_id")
  expiresAt       DateTime                    @map("expires_at")
  failedReason    String?                     @map("failed_reason")
  createdAt       DateTime                    @default(now()) @map("created_at")
  updatedAt       DateTime                    @updatedAt @map("updated_at")

  @@index([status, expiresAt])
  @@index([createdById])
  @@index([entityType, entityId])
  @@index([folderId])
  @@map("file_upload_sessions")
}
