// ─── TASKS ────────────────────────────────────────────────

enum TaskStatusEnum {
  OPEN
  IN_PROGRESS
  REVIEW
  ON_HOLD
  COMPLETED
}

enum TaskPriorityEnum {
  CRITICAL
  HIGH
  NORMAL
  LOW
}

enum WorkSpaceTypeEnum {
  PRODUCT_DELIVERY
  EXTENSION_DELIVERY
  STANDALONE_OPERATIONAL
}

enum TaskPlanningStatusEnum {
  UNPLANNED
  BACKLOG
  FUTURE_SPRINT
  ACTIVE_SPRINT
}

enum SprintStatusEnum {
  PLANNING
  ACTIVE
  CLOSED
}

model WorkSpace {
  id           String            @id @default(uuid())
  projectId    String?           @map("project_id")
  productId    String?           @unique @map("product_id")
  extensionId  String?           @unique @map("extension_id")
  name         String
  type         WorkSpaceTypeEnum
  scrumEnabled Boolean           @default(false) @map("scrum_enabled")
  description  String?
  createdAt    DateTime          @default(now()) @map("created_at")
  updatedAt    DateTime          @updatedAt @map("updated_at")

  project   Project?   @relation(fields: [projectId], references: [id])
  product   Product?   @relation(fields: [productId], references: [id])
  extension Extension? @relation(fields: [extensionId], references: [id])
  tasks     Task[]
  sprints   Sprint[]

  @@index([projectId])
  @@index([type])
  @@map("work_spaces")
}

model Sprint {
  id          String           @id @default(uuid())
  workspaceId String           @map("workspace_id")
  name        String
  goal        String?
  status      SprintStatusEnum @default(PLANNING)
  startDate   DateTime?        @map("start_date")
  endDate     DateTime?        @map("end_date")
  closedAt    DateTime?        @map("closed_at")
  sortOrder   Int              @default(0) @map("sort_order")
  createdAt   DateTime         @default(now()) @map("created_at")
  updatedAt   DateTime         @updatedAt @map("updated_at")

  workspace WorkSpace @relation(fields: [workspaceId], references: [id], onDelete: Cascade)
  tasks     Task[]

  @@index([workspaceId, status])
  @@index([workspaceId, sortOrder])
  @@map("sprints")
}

model Task {
  id                 String                 @id @default(uuid())
  code               String                 @unique
  title              String
  description        String?
  productId          String?                @map("product_id")
  extensionId        String?                @map("extension_id")
  workspaceId        String?                @map("workspace_id")
  sprintId           String?                @map("sprint_id")
  creatorId          String                 @map("creator_id")
  assigneeId         String?                @map("assignee_id")
  reviewerId         String?                @map("reviewer_id")
  coAssignees        String[]               @map("co_assignees")
  observers          String[]
  status             TaskStatusEnum         @default(OPEN)
  reviewRequestedAt  DateTime?              @map("review_requested_at")
  reviewApprovedAt   DateTime?              @map("review_approved_at")
  planningStatus     TaskPlanningStatusEnum @default(UNPLANNED) @map("planning_status")
  priority           TaskPriorityEnum       @default(NORMAL)
  dueDate            DateTime?              @map("due_date")
  completedAt        DateTime?              @map("completed_at")
  completionRules    Json?                  @map("completion_rules")
  parentId           String?                @map("parent_id")
  myPlanStageId      String?                @map("my_plan_stage_id")
  myPlanSortOrder    Int                    @default(0) @map("my_plan_sort_order")
  workspaceSortOrder Int                    @default(0) @map("workspace_sort_order")
  chatId             String?                @unique @map("chat_id")
  isRecurring        Boolean                @default(false) @map("is_recurring")
  templateTaskId     String?                @map("template_task_id")
  createdAt          DateTime               @default(now()) @map("created_at")
  updatedAt          DateTime               @updatedAt @map("updated_at")

  product    Product?        @relation(fields: [productId], references: [id])
  extension  Extension?      @relation(fields: [extensionId], references: [id])
  workspace  WorkSpace?      @relation(fields: [workspaceId], references: [id])
  sprint     Sprint?         @relation(fields: [sprintId], references: [id], onDelete: SetNull)
  creator    Employee        @relation("TaskCreator", fields: [creatorId], references: [id])
  assignee   Employee?       @relation("TaskAssignee", fields: [assigneeId], references: [id])
  reviewer   Employee?       @relation("TaskReviewer", fields: [reviewerId], references: [id])
  parent     Task?           @relation("TaskSubtasks", fields: [parentId], references: [id])
  subtasks   Task[]          @relation("TaskSubtasks")
  links      TaskLink[]
  checklists TaskChecklist[]

  @@index([workspaceId])
  @@index([sprintId])
  @@index([planningStatus])
  @@index([assigneeId])
  @@index([reviewerId])
  @@index([creatorId])
  @@map("tasks")
}

model TaskLink {
  id         String   @id @default(uuid())
  taskId     String   @map("task_id")
  entityType String   @map("entity_type")
  entityId   String   @map("entity_id")
  createdAt  DateTime @default(now()) @map("created_at")

  task Task @relation(fields: [taskId], references: [id], onDelete: Cascade)

  @@unique([taskId, entityType, entityId])
  @@index([entityType, entityId])
  @@map("task_links")
}

model TaskChecklist {
  id        String   @id @default(uuid())
  taskId    String   @map("task_id")
  title     String   @default("Checklist")
  createdAt DateTime @default(now()) @map("created_at")

  task  Task                @relation(fields: [taskId], references: [id], onDelete: Cascade)
  items TaskChecklistItem[]

  @@map("task_checklists")
}

model TaskChecklistItem {
  id          String  @id @default(uuid())
  checklistId String  @map("checklist_id")
  text        String
  checked     Boolean @default(false)
  sortOrder   Int     @default(0) @map("sort_order")

  checklist TaskChecklist @relation(fields: [checklistId], references: [id], onDelete: Cascade)

  @@map("task_checklist_items")
}

model TaskBoardStage {
  id        String   @id @default(uuid())
  ownerId   String?  @map("owner_id")
  boardType String   @map("board_type")
  title     String
  color     String   @default("#3B82F6")
  sortOrder Int      @default(0) @map("sort_order")
  isDefault Boolean  @default(false) @map("is_default")
  createdAt DateTime @default(now()) @map("created_at")

  @@unique([ownerId, boardType, title])
  @@index([ownerId, boardType])
  @@map("task_board_stages")
}

model RecurringTaskTemplate {
  id            String           @id @default(uuid())
  title         String
  description   String?
  assigneeId    String?          @map("assignee_id")
  creatorId     String           @map("creator_id")
  priority      TaskPriorityEnum @default(NORMAL)
  frequency     String
  interval      Int              @default(1)
  daysOfWeek    String[]         @map("days_of_week")
  dayOfMonth    Int?             @map("day_of_month")
  startDate     DateTime         @map("start_date")
  endDate       DateTime?        @map("end_date")
  dueDateOffset Int?             @map("due_date_offset")
  isActive      Boolean          @default(true) @map("is_active")
  lastCreatedAt DateTime?        @map("last_created_at")
  nextCreateAt  DateTime?        @map("next_create_at")
  checklistData Json?            @map("checklist_data")
  linksData     Json?            @map("links_data")
  createdAt     DateTime         @default(now()) @map("created_at")
  updatedAt     DateTime         @updatedAt @map("updated_at")

  creator  Employee  @relation("RecurringTaskCreator", fields: [creatorId], references: [id])
  assignee Employee? @relation("RecurringTaskAssignee", fields: [assigneeId], references: [id])

  @@map("recurring_task_templates")
}
