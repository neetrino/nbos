// ─── CREDENTIALS & DOMAINS ────────────────────────────────

enum CredentialCategoryEnum {
  ADMIN
  DOMAIN
  HOSTING
  SERVICE
  APP
  MAIL
  API_KEY
  DATABASE
  OTHER
}

enum CredentialAccessLevelEnum {
  SECRET
  PROJECT_TEAM
  DEPARTMENT
  ALL
  PERSONAL
}

enum CredentialTypeEnum {
  LOGIN_PASSWORD
  API_KEY
  DATABASE
  SSH_PRIVATE_KEY
  ENV_BUNDLE
  DOMAIN_REGISTRAR
  HOSTING_SERVER
  APP_STORE_ACCOUNT
  MAIL_SMTP
  RECOVERY_CODES
  OTHER_SECRET
}

enum CredentialCriticalityEnum {
  LOW
  MEDIUM
  HIGH
  CRITICAL
}

enum CredentialSecretRotationSourceEnum {
  PLANNED
  MANUAL
  EMERGENCY
}

/// Company/service catalog for credentials (hosting, mail, domain, SaaS — one list).
model CredentialProvider {
  id         String    @id @default(uuid())
  name       String
  slug       String    @unique
  website    String?
  isSeeded   Boolean   @default(false) @map("is_seeded")
  archivedAt DateTime? @map("archived_at")
  createdAt  DateTime  @default(now()) @map("created_at")
  updatedAt  DateTime  @updatedAt @map("updated_at")

  credentials Credential[]

  @@index([name])
  @@map("credential_providers")
}

model Credential {
  id                    String                    @id @default(uuid())
  projectId             String?                   @map("project_id")
  productId             String?                   @map("product_id")
  domainId              String?                   @map("domain_id")
  clientServiceRecordId String?                   @map("client_service_record_id")
  departmentId          String?                   @map("department_id")
  ownerId               String?                   @map("owner_id")
  category              CredentialCategoryEnum
  credentialType        CredentialTypeEnum        @default(LOGIN_PASSWORD) @map("credential_type")
  criticality           CredentialCriticalityEnum @default(MEDIUM)
  environment           String?
  providerId            String?                   @map("provider_id")
  name                  String
  url                   String?
  login                 String?
  password              String?
  apiKey                String?                   @map("api_key")
  envData               String?                   @map("env_data")
  phone                 String?
  notes                 String?
  publicNotes           String?                   @map("public_notes")
  secureNotes           String?                   @map("secure_notes")
  lastRotatedAt         DateTime?                 @map("last_rotated_at")
  nextRotationAt        DateTime?                 @map("next_rotation_at")
  rotationOwnerId       String?                   @map("rotation_owner_id")
  accessLevel           CredentialAccessLevelEnum @default(PROJECT_TEAM) @map("access_level")
  allowedEmployees      String[]                  @map("allowed_employees")
  archivedAt            DateTime?                 @map("archived_at")
  createdAt             DateTime                  @default(now()) @map("created_at")
  updatedAt             DateTime                  @updatedAt @map("updated_at")

  project                   Project?                   @relation(fields: [projectId], references: [id])
  department                Department?                @relation(fields: [departmentId], references: [id])
  owner                     Employee?                  @relation("CredentialOwner", fields: [ownerId], references: [id])
  provider                  CredentialProvider?        @relation(fields: [providerId], references: [id], onDelete: SetNull)
  clientServiceRecords      ClientServiceRecord[]
  mailProviderConnections   MailProviderConnection[]
  productAccessSlotBindings ProductAccessSlotBinding[]
  secretVersions            CredentialSecretVersion[]

  @@index([projectId])
  @@index([productId])
  @@index([domainId])
  @@index([clientServiceRecordId])
  @@index([category])
  @@index([credentialType])
  @@index([criticality])
  @@index([environment])
  @@index([accessLevel])
  @@index([ownerId])
  @@index([nextRotationAt])
  @@index([providerId])
  @@map("credentials")
}

model CredentialSecretVersion {
  id            String                           @id @default(uuid())
  credentialId  String                           @map("credential_id")
  field         String
  ciphertext    String
  versionNumber Int                              @map("version_number")
  rotatedAt     DateTime                         @default(now()) @map("rotated_at")
  rotatedById   String                           @map("rotated_by_id")
  source        CredentialSecretRotationSourceEnum @default(MANUAL)
  reason        String?

  credential Credential @relation(fields: [credentialId], references: [id], onDelete: Cascade)
  rotatedBy  Employee   @relation("CredentialSecretVersionRotatedBy", fields: [rotatedById], references: [id], onDelete: Restrict)

  @@index([credentialId, field])
  @@map("credential_secret_versions")
}

enum DomainStatusEnum {
  ACTIVE
  EXPIRING_SOON
  EXPIRED
  TRANSFERRED
}

model Domain {
  id                    String           @id @default(uuid())
  projectId             String           @map("project_id")
  clientServiceRecordId String?          @unique @map("client_service_record_id")
  domainName            String           @unique @map("domain_name")
  provider              String?
  purchaseDate          DateTime?        @map("purchase_date")
  expiryDate            DateTime?        @map("expiry_date")
  renewalCost           Decimal?         @map("renewal_cost") @db.Decimal(10, 2)
  clientCharge          Decimal?         @map("client_charge") @db.Decimal(10, 2)
  autoRenew             Boolean          @default(true) @map("auto_renew")
  status                DomainStatusEnum @default(ACTIVE)
  createdAt             DateTime         @default(now()) @map("created_at")
  updatedAt             DateTime         @updatedAt @map("updated_at")

  project             Project              @relation(fields: [projectId], references: [id])
  clientServiceRecord ClientServiceRecord? @relation(fields: [clientServiceRecordId], references: [id], onDelete: SetNull)

  @@map("domains")
}
