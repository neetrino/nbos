# NBOS Platform — Environment Variables
# Copy to .env.local and fill with real values

# ——— General ———
NODE_ENV="development"
NEXT_PUBLIC_API_URL="http://localhost:4000"

# ——— Database (Neon PostgreSQL) ———
DATABASE_URL="postgresql://app_user:password@ep-xxx-pooler.neon.tech/neondb?sslmode=require"
DIRECT_URL="postgresql://neon_owner:password@ep-xxx.neon.tech/neondb?sslmode=require"

# ——— Auth (Clerk) ———
NEXT_PUBLIC_CLERK_PUBLISHABLE_KEY="pk_..."
CLERK_SECRET_KEY="sk_..."
#URL Address /api/webhooks/clerk
CLERK_WEBHOOK_SIGNING_SECRET=""
NEXT_PUBLIC_CLERK_SIGN_IN_URL="/sign-in"
NEXT_PUBLIC_CLERK_SIGN_UP_URL="/sign-up"


# ——— Cache (Upstash Redis) ———
UPSTASH_REDIS_REST_URL="https://..."
UPSTASH_REDIS_REST_TOKEN=""

# ——— Email (Resend) ———
RESEND_API_KEY="re_..."
RESEND_FROM_EMAIL="nbos@neetrino.com"

# ——— File storage (Cloudflare R2) ———
R2_ACCOUNT_ID=""
R2_ACCESS_KEY_ID=""
R2_SECRET_ACCESS_KEY=""
R2_BUCKET_NAME="nbos"
R2_PUBLIC_URL=""

# ——— API ———
PORT=4000
CORS_ORIGIN="http://localhost:3000"
JWT_SECRET="your-super-secret-jwt-key-change-this-in-production"

# ——— Credentials Encryption ———
CREDENTIAL_ENCRYPTION_KEY=""

# ——— Optional ———
# SENTRY_DSN=""
# POSTHOG_API_KEY=""
