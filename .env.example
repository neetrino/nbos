# NBOS Platform — Environment Variables
# Copy to .env.local and fill with real values

# ——— Runtime ———
NODE_ENV="development"

# ——— Web (public UI origin) ———
# Один и тот же origin в адресной строке. APP_URL — ссылки в письмах/колбэках (API).
# AUTH_URL — Auth.js (сессия /api/auth/*). NEXTAUTH_URL — alias для совместимости; можно = AUTH_URL.
APP_URL="http://localhost:3000"
AUTH_URL="http://localhost:3000"
NEXTAUTH_URL="http://localhost:3000"

# ——— Web → API ———
# Nest origin для BFF и server-side login. Локально: http://localhost:4000
BACKEND_URL="http://localhost:4000"

# ——— API: browser origins (CORS, Socket.IO, Next dev LAN) ———
# Через запятую: каждый origin, с которого открываешь UI (localhost, LAN IP, staging).
# Не путать с BACKEND_URL — это allowlist для браузера, не адрес API.
CORS_ORIGIN="http://localhost:3000"

# ——— Database (Neon PostgreSQL) ———
DATABASE_URL="postgresql://app_user:password@ep-xxx-pooler.neon.tech/neondb?sslmode=require"
DIRECT_URL="postgresql://neon_owner:password@ep-xxx.neon.tech/neondb?sslmode=require"

# ——— Auth (NextAuth + собственный JWT) ———
# NextAuth: секрет для шифрования сессий (обязателен, min 32 символа)
# Сгенерировать: openssl rand -base64 32
AUTH_SECRET="generate-with-openssl-rand-base64-32"
# Backend JWT: секрет для подписи access-токенов
JWT_SECRET="your-super-secret-jwt-key-change-this-in-production"
JWT_EXPIRES_IN="7d"

# ——— Cache (Upstash Redis) ———
UPSTASH_REDIS_REST_URL="https://..."
UPSTASH_REDIS_REST_TOKEN=""

# ——— Email (Resend) ———
RESEND_API_KEY="re_..."
RESEND_FROM_EMAIL="nbos@neetrino.com"
RESEND_ADMIN_EMAIL=""
# Первый админ для bootstrap-сида: pnpm --filter @nbos/database run seed:admin
ADMIN_EMAIL=""
ADMIN_PASSWORD=""

# ——— File storage (Cloudflare R2) ———
# New uploads use nbos/tenants/{NBOS_TENANT_ORGANIZATION_ID}/files/... (storage home).
R2_ACCOUNT_ID=""
R2_ACCESS_KEY_ID=""
R2_SECRET_ACCESS_KEY=""
R2_BUCKET_NAME="nbos"
R2_PUBLIC_URL=""
# Required for Drive uploads: stable tenant UUID in R2 paths (nbos/tenants/{id}/files/...).
NBOS_TENANT_ORGANIZATION_ID="00000000-0000-4000-8000-000000000001"

# ——— API (Backend — NestJS, Coolify service nbos-api) ———
PORT=4000
# Service key for /api/scheduler/* (external cron). Required in production.
# Senders must pass it as `x-scheduler-key: <key>` or `Authorization: Bearer <key>`.
# Generate: openssl rand -base64 32
SCHEDULER_API_KEY=""
# BullMQ: report export jobs (`ReportExportJob`). Set in production with a worker consuming the same queue.
# REDIS_URL="redis://..."
# Local-only: run export processing inside the API process when Redis is unset. Never enable in production.
# REPORT_EXPORT_SYNC_FALLBACK="false"

# ——— Credentials Encryption ———
CREDENTIALS_ENCRYPTION_KEY=""

# ——— Optional ———
# Log level for nestjs-pino (trace|debug|info|warn|error). Default: info (prod) / debug (dev).
# LOG_LEVEL="info"
# SENTRY_DSN=""
# POSTHOG_API_KEY=""

# ——— API in-process scheduler (Nest) ———
# Expense plan auto-generate (due): same as POST /api/scheduler/expense-plan-auto-due.
# Default off. Set ENABLED=true to register a cron in the API process; prefer external cron in production.
# Ops recipe (curl, crontab, TZ): docs/reference/platforms/expense-plan-auto-due-external-cron.md
# External callers: NBOS_API_BASE = origin only (e.g. https://api.example.com), no trailing /api — paths already include /api/...
# SCHEDULER_EXPENSE_PLAN_AUTO_DUE_ENABLED="false"
# Five-field cron; default 02:00 daily in process TZ if unset (set TZ=UTC for UTC wall clock).
# SCHEDULER_EXPENSE_PLAN_AUTO_DUE_CRON="0 2 * * *"
