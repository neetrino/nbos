# NBOS Platform — Environment Variables
# Copy to .env.local and fill with real values

# ——— General ———
NODE_ENV="development"
APP_URL="http://localhost:3000"

# ——— Backend connection (Next.js rewrites proxy) ———
# Фронтенд проксирует /api/* запросы на бэкенд через Next.js rewrites (next.config.ts)
# Локально: не нужно задавать — fallback на http://localhost:4000
# Production (Vercel): задать адрес бэкенда на Render
# BACKEND_URL="https://your-app.onrender.com"
# Browser Socket.IO for Messenger (same host as Nest; default http://localhost:4000 if unset)
# NEXT_PUBLIC_BACKEND_URL="https://your-app.onrender.com"

# ——— Database (Neon PostgreSQL) ———
DATABASE_URL="postgresql://app_user:password@ep-xxx-pooler.neon.tech/neondb?sslmode=require"
DIRECT_URL="postgresql://neon_owner:password@ep-xxx.neon.tech/neondb?sslmode=require"

# ——— Auth (NextAuth + собственный JWT) ———
# NextAuth: секрет для шифрования сессий (обязателен, min 32 символа)
# Сгенерировать: openssl rand -base64 32
AUTH_SECRET="generate-with-openssl-rand-base64-32"
# Backend JWT: секрет для подписи access-токенов
JWT_SECRET="your-super-secret-jwt-key-change-this-in-production"
JWT_EXPIRES_IN="7d"

# ——— Cache (Upstash Redis) ———
UPSTASH_REDIS_REST_URL="https://..."
UPSTASH_REDIS_REST_TOKEN=""

# ——— Email (Resend) ———
RESEND_API_KEY="re_..."
RESEND_FROM_EMAIL="nbos@neetrino.com"
RESEND_ADMIN_EMAIL=""
# Первый админ для bootstrap-сида: pnpm --filter @nbos/database run seed:admin
ADMIN_EMAIL=""
ADMIN_PASSWORD=""

# ——— File storage (Cloudflare R2) ———
# Drive section stores files under prefix "Drive/" in this bucket (Drive/projects/{projectId}/...)
R2_ACCOUNT_ID=""
R2_ACCESS_KEY_ID=""
R2_SECRET_ACCESS_KEY=""
R2_BUCKET_NAME="nbos"
R2_PUBLIC_URL=""

# ——— API (Backend — NestJS on Render) ———
PORT=4000
CORS_ORIGIN="http://localhost:3000"
# BullMQ: report export jobs (`ReportExportJob`). Set in production with a worker consuming the same queue.
# REDIS_URL="redis://..."
# Local-only: run export processing inside the API process when Redis is unset. Never enable in production.
# REPORT_EXPORT_SYNC_FALLBACK="false"

# ——— Credentials Encryption ———
CREDENTIALS_ENCRYPTION_KEY=""

# ——— Optional ———
# SENTRY_DSN=""
# POSTHOG_API_KEY=""

# ——— API in-process scheduler (Nest) ———
# Expense plan auto-generate (due): same as POST /api/scheduler/expense-plan-auto-due.
# Default off. Set ENABLED=true to register a cron in the API process; prefer external cron in production.
# Ops recipe (curl, crontab, TZ): docs/reference/platforms/expense-plan-auto-due-external-cron.md
# External callers: NBOS_API_BASE = origin only (e.g. https://api.example.com), no trailing /api — paths already include /api/...
# SCHEDULER_EXPENSE_PLAN_AUTO_DUE_ENABLED="false"
# Five-field cron; default 02:00 daily in process TZ if unset (set TZ=UTC for UTC wall clock).
# SCHEDULER_EXPENSE_PLAN_AUTO_DUE_CRON="0 2 * * *"
